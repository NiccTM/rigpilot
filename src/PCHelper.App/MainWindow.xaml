<Window x:Class="PCHelper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Helper"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <DataTemplate x:Key="CapabilityTemplate">
      <Grid Margin="0,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Reason}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" />
        </StackPanel>
        <Border Grid.Column="1" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding State}" />
        </Border>
      </Grid>
    </DataTemplate>
  </Window.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="210" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#15181E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="8,8,8,24">
          <TextBlock Text="PC Helper" FontSize="22" FontWeight="SemiBold" />
          <TextBlock Text="Cross-vendor control" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
        </StackPanel>
        <Border DockPanel.Dock="Bottom" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="12">
          <StackPanel>
            <TextBlock Text="Service" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ServiceStatusText}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
        </Border>
        <ListBox x:Name="Navigation" SelectionChanged="Navigation_SelectionChanged" SelectedIndex="0">
          <ListBoxItem Content="Overview" Padding="12,10" />
          <ListBoxItem Content="Profiles" Padding="12,10" />
          <ListBoxItem Content="Cooling" Padding="12,10" />
          <ListBoxItem Content="Performance" Padding="12,10" />
          <ListBoxItem Content="Lighting" Padding="12,10" />
          <ListBoxItem Content="Automation" Padding="12,10" />
          <ListBoxItem Content="Devices" Padding="12,10" />
          <ListBoxItem Content="Diagnostics" Padding="12,10" />
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" Margin="24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <DockPanel Grid.Row="0" Margin="0,0,0,18">
        <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" />
        <StackPanel>
          <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource PageHeaderStyle}" />
          <TextBlock Text="{Binding CurrentPageSubtitle}" Style="{StaticResource MutedStyle}" />
        </StackPanel>
      </DockPanel>

      <Grid Grid.Row="1">
        <ScrollViewer x:Name="OverviewPage" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <UniformGrid Columns="4">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Devices" Style="{StaticResource MutedStyle}" />
                  <TextBlock Text="{Binding DeviceCount}" FontSize="28" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Live sensors" Style="{StaticResource MutedStyle}" />
                  <TextBlock Text="{Binding SensorCount}" FontSize="28" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Write controls" Style="{StaticResource MutedStyle}" />
                  <TextBlock Text="{Binding VerifiedControlCount}" FontSize="28" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Active profile" Style="{StaticResource MutedStyle}" />
                  <TextBlock Text="{Binding ActiveProfileName}" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
                </StackPanel>
              </Border>
            </UniformGrid>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Important sensors" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding ImportantSensors}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="130" />
                          <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" />
                        <TextBlock Grid.Column="1" Text="{Binding Device}" Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Grid.Column="2" Text="{Binding DisplayValue}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0">
              <StackPanel>
                <TextBlock Text="Safety status" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SafetySummary}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{StaticResource SafeBrush}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="ProfilesPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Stock-safe profiles" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Built-in profiles contain no above-stock CPU or GPU values. Unsupported optional actions are shown before apply." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,14" />
                <ItemsControl ItemsSource="{Binding Profiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                        <DockPanel>
                          <Button DockPanel.Dock="Right" Content="Apply" Command="{Binding DataContext.ApplyProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                          <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="CoolingPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Cooling ownership" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Detected fan and pump controls remain read-only until the exact controller passes calibration, read-back, reset, crash, and reboot checks." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                <ItemsControl ItemsSource="{Binding CoolingCapabilities}" ItemTemplate="{StaticResource CapabilityTemplate}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="PerformancePage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="CPU and GPU controls" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Reverse-engineered controls will be marked Experimental and driver-gated. This build exposes monitoring and verified Windows power policy only." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                <ItemsControl ItemsSource="{Binding PerformanceCapabilities}" ItemTemplate="{StaticResource CapabilityTemplate}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="LightingPage" Visibility="Collapsed">
          <Border Style="{StaticResource CardStyle}" Margin="0">
            <StackPanel>
              <TextBlock Text="OpenRGB bridge" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="PC Helper will connect only to an explicitly enabled, installed OpenRGB SDK server. OpenRGB is not bundled and no lighting writes are enabled in this build." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </ScrollViewer>

        <ScrollViewer x:Name="AutomationPage" Visibility="Collapsed">
          <Border Style="{StaticResource CardStyle}" Margin="0">
            <StackPanel>
              <TextBlock Text="Automation policy" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="Manual selection takes precedence. Future process and schedule rules use explicit priority, 5-second entry debounce, 15-second exit debounce, and a 30-second switch cooldown." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </ScrollViewer>

        <ScrollViewer x:Name="DevicesPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Devices}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Details}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <ScrollViewer x:Name="DiagnosticsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Warnings and conflicts" FontSize="18" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Diagnostics}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{StaticResource WarningBrush}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0">
              <StackPanel>
                <TextBlock Text="Compatibility report" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Generate a local redacted preview. It will not be uploaded and remains marked unapproved until a separate consent step is implemented." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,14" />
                <StackPanel Orientation="Horizontal">
                  <Button Content="Save report preview" Click="SaveReport_Click" />
                  <Button Content="Reset verified controls" Command="{Binding ResetVerifiedCommand}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>

</Window>
