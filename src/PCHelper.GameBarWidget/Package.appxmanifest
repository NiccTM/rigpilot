<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  IgnorableNamespaces="uap uap3 mp">
  <Identity Name="RigPilot.GameBarWidget" Publisher="CN=RigPilot Developers" Version="0.4.0.0" />
  <mp:PhoneIdentity PhoneProductId="D927B825-16F0-4DCF-80EE-2F4C12D82D57" PhonePublisherId="00000000-0000-0000-0000-000000000000" />
  <Properties>
    <DisplayName>RigPilot Game Bar</DisplayName>
    <PublisherDisplayName>RigPilot</PublisherDisplayName>
    <Logo>Assets\RigPilotStore.png</Logo>
  </Properties>
  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>
  <Resources><Resource Language="x-generate" /></Resources>
  <Applications>
    <Application Id="App" Executable="$targetnametoken$.exe" EntryPoint="PCHelper.GameBarWidget.App">
      <uap:VisualElements
        DisplayName="RigPilot Game Bar"
        Square150x150Logo="Assets\RigPilotMark150.png"
        Square44x44Logo="Assets\RigPilotMark44.png"
        Description="RigPilot read-only Game Bar companion"
        BackgroundColor="transparent">
        <uap:SplashScreen Image="Assets\RigPilotSplash.png" />
      </uap:VisualElements>
      <Extensions>
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension
            Name="microsoft.gameBarUIExtension"
            Id="RigPilotOverlay"
            DisplayName="RigPilot"
            Description="RigPilot read-only system status"
            PublicFolder="GameBar">
            <uap3:Properties>
              <GameBarWidget Type="Standard">
                <HomeMenuVisible>true</HomeMenuVisible>
                <PinningSupported>true</PinningSupported>
                <Window>
                  <Size><Height>250</Height><Width>420</Width><MinHeight>180</MinHeight><MinWidth>300</MinWidth><MaxHeight>420</MaxHeight><MaxWidth>600</MaxWidth></Size>
                  <ResizeSupported><Horizontal>true</Horizontal><Vertical>true</Vertical></ResizeSupported>
                </Window>
              </GameBarWidget>
            </uap3:Properties>
          </uap3:AppExtension>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>
  <Extensions>
