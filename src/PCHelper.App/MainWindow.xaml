<Window x:Class="PCHelper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Helper"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <DataTemplate x:Key="CapabilityTemplate">
      <Grid Margin="0,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Reason}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" />
        </StackPanel>
        <Border Grid.Column="1" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding State}" />
        </Border>
      </Grid>
    </DataTemplate>
  </Window.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="210" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#12151B" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="8,10,8,22" Orientation="Horizontal">
          <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Width="36" Height="36">
            <TextBlock Text="&#xE950;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="PC Helper" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Cross-vendor control" Style="{StaticResource MutedStyle}" FontSize="12" />
          </StackPanel>
        </StackPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Margin="0,12,0,0" Padding="12">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <Ellipse x:Name="ServiceDot" Width="9" Height="9" VerticalAlignment="Center" Margin="0,1,7,0">
                <Ellipse.Style>
                  <Style TargetType="Ellipse">
                    <Setter Property="Fill" Value="{StaticResource SeriousBrush}" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsServiceOnline}" Value="True">
                        <Setter Property="Fill" Value="{StaticResource SafeBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Ellipse.Style>
              </Ellipse>
              <TextBlock Text="Service" FontWeight="SemiBold" />
              <TextBlock Text="{Binding ServiceStateLabel}" Style="{StaticResource MutedStyle}" Margin="6,0,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding ServiceStatusText}" Style="{StaticResource MutedStyle}" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0" />
          </StackPanel>
        </Border>
        <ListBox x:Name="Navigation" SelectionChanged="Navigation_SelectionChanged" SelectedIndex="0">
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE80F;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Overview" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE771;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Profiles" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE9CA;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Cooling" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE945;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Performance" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE706;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Lighting" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Automation" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE772;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Devices" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem Padding="10,9">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBlock Text="Diagnostics" VerticalAlignment="Center" />
            </StackPanel>
          </ListBoxItem>
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" Margin="24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <DockPanel Grid.Row="0" Margin="0,0,0,18">
        <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center" />
        <StackPanel>
          <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource PageHeaderStyle}" />
          <TextBlock Text="{Binding CurrentPageSubtitle}" Style="{StaticResource MutedStyle}" />
        </StackPanel>
      </DockPanel>

      <Grid Grid.Row="1">
        <ScrollViewer x:Name="OverviewPage" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,0,10,0">
            <UniformGrid Columns="4">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="DEVICES" Style="{StaticResource SectionLabelStyle}" />
                  <TextBlock Text="{Binding DeviceCount}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="LIVE SENSORS" Style="{StaticResource SectionLabelStyle}" />
                  <TextBlock Text="{Binding SensorCount}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="WRITE CONTROLS" Style="{StaticResource SectionLabelStyle}" />
                  <TextBlock Text="{Binding VerifiedControlCount}" FontSize="30" FontWeight="SemiBold" Margin="0,6,0,0" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="ACTIVE PROFILE" Style="{StaticResource SectionLabelStyle}" />
                  <TextBlock Text="{Binding ActiveProfileName}" FontSize="22" FontWeight="SemiBold" Margin="0,11,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </Border>
            </UniformGrid>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Important sensors" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding ImportantSensors}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="1.2*" />
                          <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Device}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="2" Text="{Binding DisplayValue}" HorizontalAlignment="Right" FontWeight="SemiBold">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Severity}" Value="Warm">
                                  <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Hot">
                                  <Setter Property="Foreground" Value="{StaticResource SeriousBrush}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0">
              <StackPanel>
                <TextBlock Text="Safety status" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SafetySummary}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{StaticResource SafeBrush}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="ProfilesPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Stock-safe profiles" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Built-in profiles contain no above-stock CPU or GPU values. Unsupported optional actions are shown before apply." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,14" />
                <ItemsControl ItemsSource="{Binding Profiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                        <DockPanel>
                          <Button DockPanel.Dock="Right" Content="Apply" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center" Command="{Binding DataContext.ApplyProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                          <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="CoolingPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Cooling ownership" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Detected fan and pump controls remain read-only until the exact controller passes calibration, read-back, reset, crash, and reboot checks." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                <ItemsControl ItemsSource="{Binding CoolingCapabilities}" ItemTemplate="{StaticResource CapabilityTemplate}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="PerformancePage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="CPU and GPU controls" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Reverse-engineered controls will be marked Experimental and driver-gated. This build exposes monitoring and verified Windows power policy only." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                <ItemsControl ItemsSource="{Binding PerformanceCapabilities}" ItemTemplate="{StaticResource CapabilityTemplate}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="LightingPage" Visibility="Collapsed">
          <Border Style="{StaticResource CardStyle}" Margin="0">
            <StackPanel>
              <TextBlock Text="OpenRGB bridge" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="PC Helper will connect only to an explicitly enabled, installed OpenRGB SDK server. OpenRGB is not bundled and no lighting writes are enabled in this build." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </ScrollViewer>

        <ScrollViewer x:Name="AutomationPage" Visibility="Collapsed">
          <Border Style="{StaticResource CardStyle}" Margin="0">
            <StackPanel>
              <TextBlock Text="Automation policy" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="Manual selection takes precedence. Future process and schedule rules use explicit priority, 5-second entry debounce, 15-second exit debounce, and a 30-second switch cooldown." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </ScrollViewer>

        <ScrollViewer x:Name="DevicesPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Devices}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Details}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <ScrollViewer x:Name="DiagnosticsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Warnings and conflicts" FontSize="18" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Diagnostics}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{StaticResource WarningBrush}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0">
              <StackPanel>
                <TextBlock Text="Compatibility report" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Generate a local redacted preview. It will not be uploaded and remains marked unapproved until a separate consent step is implemented." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,14" />
                <StackPanel Orientation="Horizontal">
                  <Button Content="Save report preview" Click="SaveReport_Click" />
                  <Button Content="Reset verified controls" Command="{Binding ResetVerifiedCommand}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>

</Window>
