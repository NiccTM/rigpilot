<Window x:Class="PCHelper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PCHelper.App"
        xmlns:loc="clr-namespace:PCHelper.App.Localization"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="RigPilot — Overview"
        Icon="{StaticResource RigPilotMark}"
        Width="1240"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="Window_PreviewKeyDown">
  <Window.InputBindings>
    <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    <KeyBinding Key="R" Modifiers="Control" Command="{Binding RefreshCommand}" />
  </Window.InputBindings>

  <Window.Resources>
    <!-- Simple mode is intentionally task-focused. Advanced Lab exposes the
         calibration, import, ownership, and qualification surface without
         removing it from the application. Keep these styles on containers so
         the child controls retain their normal styling and accessibility IDs. -->
    <Style x:Key="AdvancedOnlyPanelStyle" TargetType="{x:Type FrameworkElement}">
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsAdvancedLab}" Value="True">
          <Setter Property="Visibility" Value="Visible" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SimpleOnlyPanelStyle" TargetType="{x:Type FrameworkElement}">
      <Setter Property="Visibility" Value="Visible" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsAdvancedLab}" Value="True">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="CapabilityTemplate">
      <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,13">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Margin="0,0,16,0">
            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
            <TextBlock Text="{Binding Reason}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
          <Border Grid.Column="1" CornerRadius="12" Padding="9,4" VerticalAlignment="Top">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding StateTone}" Value="Safe">
                    <Setter Property="Background" Value="{StaticResource SafeSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource SafeBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding StateTone}" Value="Warning">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding StateTone}" Value="Critical">
                    <Setter Property="Background" Value="{StaticResource CriticalSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource CriticalBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="{Binding State}" Style="{StaticResource BadgeTextStyle}" />
          </Border>
          <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,9,0,0">
            <TextBlock Text="{Binding Domain}" Style="{StaticResource SubtleStyle}" Margin="0,0,16,0" />
            <TextBlock Text="{Binding Range}" Style="{StaticResource SubtleStyle}" Margin="0,0,16,0" />
            <TextBlock Text="{Binding Evidence, StringFormat=Evidence: {0}}" Style="{StaticResource SubtleStyle}" Margin="0,0,16,0" />
            <TextBlock Text="{Binding Risk, StringFormat=Risk: {0}}" Style="{StaticResource SubtleStyle}" Margin="0,0,16,0" />
            <TextBlock Text="{Binding Owner}" Style="{StaticResource SubtleStyle}" />
          </WrapPanel>
          <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="7" Padding="9,6" Margin="0,10,0,0">
            <TextBlock Text="{Binding NextSafeStep}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" />
          </Border>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="DiagnosticTemplate">
      <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,13">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="34" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border Width="28" Height="28" CornerRadius="7" Background="{StaticResource WarningSoftBrush}" VerticalAlignment="Top">
            <TextBlock Text="{Binding Glyph}" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" Margin="8,0,16,0">
            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Message}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,3,0,0" />
            <TextBlock Text="{Binding Remediation}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
          </StackPanel>
          <Border Grid.Column="2" CornerRadius="12" Padding="8,3" Background="{StaticResource WarningSoftBrush}" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1" VerticalAlignment="Top">
            <TextBlock Text="{Binding Severity}" Style="{StaticResource BadgeTextStyle}" Foreground="{StaticResource WarningBrush}" />
          </Border>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Grid Background="{StaticResource WindowBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="226" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Navigation shell -->
    <Border Grid.Column="0"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel Margin="14,16,14,14">
        <StackPanel DockPanel.Dock="Top" Margin="7,2,7,22">
          <StackPanel Orientation="Horizontal">
            <Image Source="{StaticResource RigPilotMark}"
                   Width="40"
                   Height="40"
                   ToolTip="RigPilot"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
              <TextBlock Text="RigPilot" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="{x:Static local:ProductBrand.Tagline}" Style="{StaticResource SubtleStyle}" Margin="0,1,0,0" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom">
          <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,12,0,0">
            <StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0">
                  <Ellipse.Style>
                    <Style TargetType="Ellipse">
                      <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ConnectionTone}" Value="Safe">
                          <Setter Property="Fill" Value="{StaticResource SafeBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ConnectionTone}" Value="Neutral">
                          <Setter Property="Fill" Value="{StaticResource SubtleTextBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Ellipse.Style>
                </Ellipse>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                  <TextBlock Text="Service" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ServiceStateLabel}" Style="{StaticResource MutedStyle}" Margin="6,0,0,0" />
                </StackPanel>
              </Grid>
              <TextBlock Text="{Binding ServiceStatusText}" ToolTip="{Binding ServiceStatusText}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,7,0,0" />
              <TextBlock Text="{Binding ServiceCompatibilityLabel}" FontWeight="SemiBold" Margin="0,8,0,0" />
              <TextBlock Text="{Binding ServiceCompatibilityMessage}" ToolTip="{Binding ServiceCompatibilityMessage}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,3,0,0" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Runtime.Compatibility" />
              <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,10,0,8" />
              <Grid>
                <TextBlock Text="Source" Style="{StaticResource SubtleStyle}" />
                <TextBlock Text="{Binding DataSourceLabel}" HorizontalAlignment="Right" FontSize="12" />
              </Grid>
            </StackPanel>
          </Border>
          <TextBlock Text="Ctrl+Shift+F12 opens RigPilot"
                     Style="{StaticResource SubtleStyle}"
                     TextAlignment="Center"
                     Margin="4,10,4,0" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <TextBlock Text="CONTROL" Style="{StaticResource EyebrowStyle}" Margin="11,0,0,5" />
            <ListBox x:Name="Navigation"
                     SelectionChanged="Navigation_SelectionChanged"
                     SelectedIndex="0"
                     automation:AutomationProperties.Name="RigPilot pages"
                     automation:AutomationProperties.AutomationId="Navigation.Pages">
              <ListBoxItem ToolTip="Overview (Ctrl+1)" automation:AutomationProperties.Name="Overview" automation:AutomationProperties.AutomationId="Navigation.Overview">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE80F;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Overview}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Profiles (Ctrl+2)" automation:AutomationProperties.Name="Profiles" automation:AutomationProperties.AutomationId="Navigation.Profiles">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE771;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Profiles}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Cooling (Ctrl+3)" automation:AutomationProperties.Name="Cooling" automation:AutomationProperties.AutomationId="Navigation.Cooling">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE9CA;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Cooling}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Performance (Ctrl+4)" automation:AutomationProperties.Name="Performance" automation:AutomationProperties.AutomationId="Navigation.Performance">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE945;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Performance}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Lighting (Ctrl+5)" automation:AutomationProperties.Name="Lighting" automation:AutomationProperties.AutomationId="Navigation.Lighting">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE706;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Lighting}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Automation (Ctrl+6)" automation:AutomationProperties.Name="Automation" automation:AutomationProperties.AutomationId="Navigation.Automation">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Automation}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Games and user-session tools (Ctrl+7)" automation:AutomationProperties.Name="Games and tools" automation:AutomationProperties.AutomationId="Navigation.GamesTools">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE7FC;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_GamesTools}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Devices (Ctrl+8)" automation:AutomationProperties.Name="Devices" automation:AutomationProperties.AutomationId="Navigation.Devices">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE772;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Devices}" />
                </StackPanel>
              </ListBoxItem>
              <ListBoxItem ToolTip="Diagnostics and settings (Ctrl+9)" automation:AutomationProperties.Name="Diagnostics and settings" automation:AutomationProperties.AutomationId="Navigation.Diagnostics">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="15" Width="22" />
                  <TextBlock Text="{loc:Loc Nav_Diagnostics}" />
                </StackPanel>
              </ListBoxItem>
            </ListBox>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- Main workspace -->
    <Grid Grid.Column="1" Background="{StaticResource WindowBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="28,22,28,17">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource PageHeaderStyle}" />
          <TextBlock Text="{Binding CurrentPageSubtitle}" Style="{StaticResource MutedStyle}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{StaticResource SurfaceRaisedBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="10,5"
                  Margin="0,0,8,0"
                  ToolTip="{Binding InterfaceModeDescription}"
                  automation:AutomationProperties.Name="Current interface mode"
                  automation:AutomationProperties.AutomationId="Header.InterfaceMode">
            <TextBlock Text="{Binding InterfaceModeLabel}" Style="{StaticResource BadgeTextStyle}" />
          </Border>
          <Button Command="{Binding ToggleAdvancedLabCommand}"
                  Margin="0,0,10,0"
                  ToolTip="Switch between daily controls and exact capability detail"
                  automation:AutomationProperties.Name="Toggle Advanced Lab"
                  automation:AutomationProperties.AutomationId="Header.ToggleAdvancedLab">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" Margin="0,0,7,0" />
              <TextBlock Text="{Binding InterfaceModeActionLabel}" FontWeight="SemiBold" />
            </StackPanel>
          </Button>
          <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="{Binding LastUpdatedText}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" />
            <TextBlock Text="F5 to refresh" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,0" />
          </StackPanel>
          <Button Command="{Binding RefreshCommand}"
                  Style="{StaticResource PrimaryButtonStyle}"
                  ToolTip="Refresh inventory and live readings (F5)"
                  automation:AutomationProperties.Name="Refresh hardware state"
                  automation:AutomationProperties.AutomationId="Header.Refresh">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" Foreground="#07101B" Margin="0,0,8,0" />
              <TextBlock Text="Refresh" Foreground="#07101B" FontWeight="SemiBold" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Non-modal operation feedback -->
      <Border Grid.Row="1" Margin="28,0,28,14" CornerRadius="9" Padding="13,10" automation:AutomationProperties.LiveSetting="Polite">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasNotice}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
              <DataTrigger Binding="{Binding NoticeTone}" Value="Success">
                <Setter Property="Background" Value="{StaticResource SafeSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource SafeBrush}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding NoticeTone}" Value="Warning">
                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding NoticeTone}" Value="Error">
                <Setter Property="Background" Value="{StaticResource CriticalSoftBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource CriticalBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Command="{Binding DismissNoticeCommand}"
                  Style="{StaticResource GhostButtonStyle}"
                  Padding="8,3"
                  MinHeight="0"
                  ToolTip="Dismiss message"
                  automation:AutomationProperties.Name="Dismiss message">
            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
          </Button>
          <TextBlock Text="&#xE946;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBlock Text="{Binding NoticeText}" TextWrapping="Wrap" VerticalAlignment="Center" />
        </DockPanel>
      </Border>

      <Grid Grid.Row="2" Margin="28,0,16,0">
        <!-- Overview -->
        <ScrollViewer x:Name="OverviewPage" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <local:AdaptiveUniformGrid MaximumColumns="4" MinimumColumns="2" MinimumItemWidth="230">
              <Border Style="{StaticResource CardStyle}" Padding="17">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="38" />
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="DEVICES" Style="{StaticResource EyebrowStyle}" />
                    <TextBlock Text="{Binding DeviceCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" />
                    <TextBlock Text="Enumerated hardware" Style="{StaticResource SubtleStyle}" />
                  </StackPanel>
                  <Border Grid.Column="1" Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Top">
                    <TextBlock Text="&#xE772;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </Grid>
              </Border>
              <Border Style="{StaticResource CardStyle}" Padding="17">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="38" />
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="LIVE SENSORS" Style="{StaticResource EyebrowStyle}" />
                    <TextBlock Text="{Binding SensorCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" />
                    <TextBlock Text="Current readings" Style="{StaticResource SubtleStyle}" />
                  </StackPanel>
                  <Border Grid.Column="1" Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Top">
                    <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </Grid>
              </Border>
              <Border Style="{StaticResource CardStyle}" Padding="17">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="38" />
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="VERIFIED CONTROLS" Style="{StaticResource EyebrowStyle}" />
                    <TextBlock Text="{Binding VerifiedControlCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" />
                    <TextBlock Text="Write-capable" Style="{StaticResource SubtleStyle}" />
                  </StackPanel>
                  <Border Grid.Column="1" Width="34" Height="34" CornerRadius="9" Background="{StaticResource SafeSoftBrush}" VerticalAlignment="Top">
                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource SafeBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </Grid>
              </Border>
              <Border Style="{StaticResource CardStyle}" Padding="17">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="38" />
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="ACTIVE PROFILE" Style="{StaticResource EyebrowStyle}" />
                    <TextBlock Text="{Binding ActiveProfileName}" FontSize="22" FontWeight="SemiBold" Margin="0,9,0,4" />
                    <TextBlock Text="Manual selection wins" Style="{StaticResource SubtleStyle}" />
                  </StackPanel>
                  <Border Grid.Column="1" Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Top">
                    <TextBlock Text="&#xE771;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </Grid>
              </Border>
            </local:AdaptiveUniformGrid>

            <Grid x:Name="SimpleOverviewGuide" Style="{StaticResource SimpleOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,12,0,0" Background="{StaticResource AccentSoftBrush}" BorderBrush="#31557F">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                  <Border Width="34" Height="34" CornerRadius="9" Background="#203D60" VerticalAlignment="Top">
                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="Daily controls" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="Use Profiles for stock-safe changes and keep an eye on these core readings. Experimental controls, calibration, raw trends, ownership details, imports, and qualification evidence are available only in Advanced Lab." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <Grid x:Name="AdvancedOverviewBanner" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,12,0,0" Background="{StaticResource SurfaceRaisedBrush}">
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Top">
                    <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="Advanced Lab workspace" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="Raw monitoring, sensor comparison, event history, exact capability evidence, imports, and commissioning tools are now available below. Hardware writes remain evidence-gated." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <Border Grid.Column="2" Background="{StaticResource AccentSoftBrush}" CornerRadius="12" Padding="9,4" Margin="14,0,0,0" VerticalAlignment="Top">
                    <TextBlock Text="ADVANCED" Style="{StaticResource BadgeTextStyle}" Foreground="{StaticResource AccentBrush}" />
                  </Border>
                </Grid>
              </Border>
            </Grid>

            <Grid x:Name="ExperimentalControlCenter" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,12,0,0" Background="{StaticResource WarningSoftBrush}" BorderBrush="{StaticResource WarningBrush}">
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource SurfaceRaisedBrush}" VerticalAlignment="Top">
                      <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="Experimental Control Center" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock Text="Review exact controls before commissioning. This surface is explanatory: opening a route or recording an acknowledgement never sends a hardware command." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border Grid.Column="2" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1" CornerRadius="12" Padding="9,4" Margin="14,0,0,0" VerticalAlignment="Top">
                      <TextBlock Text="{Binding ExperimentalGateBadge}" Style="{StaticResource BadgeTextStyle}" Foreground="{StaticResource WarningBrush}" />
                    </Border>
                  </Grid>

                  <TextBlock Text="{Binding ExperimentalGateSummary}" TextWrapping="Wrap" Margin="0,14,0,0" automation:AutomationProperties.LiveSetting="Polite" />

                  <local:AdaptiveUniformGrid MaximumColumns="3" MinimumColumns="1" MinimumItemWidth="220" Margin="0,14,0,2">
                    <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,0,10,10"><StackPanel><TextBlock Text="DETECTED" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding ExperimentalControlCount}" FontSize="24" FontWeight="SemiBold" Margin="0,5,0,0" /><TextBlock Text="Experimental capabilities" Style="{StaticResource SubtleStyle}" Margin="0,2,0,0" /></StackPanel></Border>
                    <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,0,10,10"><StackPanel><TextBlock Text="HEADER PATH" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding CommissioningEligibleExperimentalControlCount}" FontSize="24" FontWeight="SemiBold" Margin="0,5,0,0" /><TextBlock Text="Bounded non-protected fan outputs" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,0" /></StackPanel></Border>
                    <Border Style="{StaticResource InsetCardStyle}" Padding="12" Margin="0,0,10,10"><StackPanel><TextBlock Text="PROTECTED" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding ProtectedExperimentalControlCount}" FontSize="24" FontWeight="SemiBold" Margin="0,5,0,0" /><TextBlock Text="Pump or CPU-fan safety roles" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,0" /></StackPanel></Border>
                  </local:AdaptiveUniformGrid>

                  <CheckBox IsChecked="{Binding AdvancedWritesAcknowledged}" Margin="0,2,0,0" automation:AutomationProperties.Name="Acknowledge Experimental hardware controls for this session" automation:AutomationProperties.AutomationId="Overview.AcknowledgeExperimental">
                    <TextBlock Text="I understand Experimental controls can misconfigure unsupported hardware. This session-only acknowledgement does not bypass exact-device confirmation, commissioning, or CPU/pump protection." TextWrapping="Wrap" />
                  </CheckBox>
                  <TextBlock Text="{Binding ExperimentalAcknowledgementDetail}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />

                  <WrapPanel Margin="0,12,0,3">
                    <Button Content="Open Cooling commissioning" Click="OpenExperimentalCooling_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.Name="Open Cooling commissioning" automation:AutomationProperties.AutomationId="Overview.OpenCoolingCommissioning" />
                    <Button Content="Open device evidence" Click="OpenExperimentalDevices_Click" Margin="0,0,8,8" automation:AutomationProperties.Name="Open device evidence" automation:AutomationProperties.AutomationId="Overview.OpenDeviceEvidence" />
                  </WrapPanel>

                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,8,0,0" Padding="0">
                    <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                      <ItemsControl ItemsSource="{Binding ExperimentalControls}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12">
                              <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                  <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="1" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="7,3" Margin="8,0,0,0">
                                      <TextBlock Text="{Binding Path}" Style="{StaticResource BadgeTextStyle}" />
                                    </Border>
                                  </Grid>
                                  <TextBlock Text="{Binding Device}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                  <TextBlock Margin="0,4,0,0" Style="{StaticResource SubtleStyle}"><Run Text="{Binding Domain}" /><Run Text="  ·  " /><Run Text="{Binding Range}" /><Run Text="  ·  " /><Run Text="{Binding Evidence}" /></TextBlock>
                                  <TextBlock Text="{Binding Readiness}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                  <TextBlock Text="{Binding NextSafeStep}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Open Cooling" Click="OpenExperimentalCooling_Click" IsEnabled="{Binding CanOpenCoolingCommissioning}" VerticalAlignment="Center" ToolTip="Routes only bounded, non-protected motherboard fan controls into the existing commissioning wizard. No hardware command is sent." automation:AutomationProperties.Name="{Binding Name, StringFormat=Open cooling commissioning for {0}}" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                </StackPanel>
              </Border>
            </Grid>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
              <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                  <Grid Margin="0,0,0,8">
                    <StackPanel>
                      <TextBlock Text="Important sensors" Style="{StaticResource CardTitleStyle}" />
                      <TextBlock Text="Curated temperatures, fan speeds, and power" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4">
                      <TextBlock Text="LIVE" Style="{StaticResource BadgeTextStyle}" Foreground="{StaticResource SafeBrush}" />
                    </Border>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding ImportantSensors}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="30" />
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="1.1*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="25" Height="25" CornerRadius="6" Background="{StaticResource SurfaceRaisedBrush}">
                              <TextBlock Text="{Binding Glyph}" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Margin="7,0,10,0" />
                            <TextBlock Grid.Column="2" Text="{Binding Device}" Style="{StaticResource MutedStyle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="3" Text="{Binding DisplayValue}" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding Severity}" Value="Warm">
                                      <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="Hot">
                                      <Setter Property="Foreground" Value="{StaticResource CriticalBrush}" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Border Margin="0,10,0,0">
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasImportantSensors}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="22" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                      <TextBlock Text="No reliable live readings yet" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0" />
                      <TextBlock Text="Refresh after hardware discovery completes." Style="{StaticResource MutedStyle}" HorizontalAlignment="Center" Margin="0,3,0,0" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="20">
                  <StackPanel>
                    <Grid>
                      <StackPanel>
                        <TextBlock Text="Safety state" Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Text="Write policy and rollback readiness" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                      </StackPanel>
                      <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="12" Padding="9,4">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SafetyTone}" Value="Safe">
                                <Setter Property="Background" Value="{StaticResource SafeSoftBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource SafeBrush}" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding SafetyTone}" Value="Warning">
                                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding SafetyTone}" Value="Critical">
                                <Setter Property="Background" Value="{StaticResource CriticalSoftBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource CriticalBrush}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding WriteStateLabel}" Style="{StaticResource BadgeTextStyle}" />
                      </Border>
                    </Grid>
                    <TextBlock Text="{Binding SafetySummary}" TextWrapping="Wrap" Margin="0,15,0,0" />
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="20">
                  <StackPanel>
                    <TextBlock Text="Control readiness" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Every control is classified before it can be used" Style="{StaticResource MutedStyle}" Margin="0,3,0,12" />
                    <Grid Margin="0,5">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SafeBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Text="Verified" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding VerifiedControlCount}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,5">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Text="Read-only" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding ReadOnlyControlCount}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,5">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Text="Experimental" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding ExperimentalControlCount}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,5">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource CriticalBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Text="Blocked or unsupported" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding BlockedOrUnsupportedControlCount}" FontWeight="SemiBold" />
                    </Grid>
                  </StackPanel>
                </Border>
              </StackPanel>
            </local:AdaptiveUniformGrid>

            <Grid x:Name="AdvancedOverviewWorkspace" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <StackPanel>
              <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
                <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                  <Grid>
                    <StackPanel>
                      <TextBlock Text="Live monitoring workspace" Style="{StaticResource CardTitleStyle}" />
                      <TextBlock Text="Rolling local trends. Pins and aliases are stored per signed-in user." Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4">
                      <TextBlock Text="{Binding VisibleMonitoringTrends.Count, StringFormat={}{0} shown}" Style="{StaticResource BadgeTextStyle}" />
                    </Border>
                  </Grid>
                  <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="155" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <ComboBox ItemsSource="{Binding MonitoringTrendScopes}" SelectedItem="{Binding SelectedMonitoringTrendScope}" automation:AutomationProperties.Name="Monitoring trend filter" automation:AutomationProperties.AutomationId="Overview.TrendFilter" />
                    <TextBlock Grid.Column="1" Text="{Binding MonitoringTrendFilterSummary}" Style="{StaticResource SubtleStyle}" VerticalAlignment="Center" Margin="10,0,0,0" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding VisibleMonitoringTrends}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,9">
                          <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                              <WrapPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="  " /><TextBlock Text="{Binding Sparkline}" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" /></WrapPanel>
                              <TextBlock Text="{Binding Range}" Style="{StaticResource SubtleStyle}" Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Latest}" FontWeight="SemiBold" VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="No live trends match this filter." Margin="0,10,0,0">
                    <TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasVisibleMonitoringTrends}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                  </TextBlock>
                  <TextBlock Text="Select and customize any sensor in Diagnostics." Style="{StaticResource SubtleStyle}" Margin="0,10,0,0" />
                </StackPanel>
              </Border>
                <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                  <Grid>
                    <StackPanel><TextBlock Text="What changed?" Style="{StaticResource CardTitleStyle}" /><TextBlock Text="Profiles, competing writers, adapter activity, and safety events." Style="{StaticResource MutedStyle}" Margin="0,3,0,0" /></StackPanel>
                    <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4"><TextBlock Text="{Binding VisibleTimelineEvents.Count, StringFormat={}{0} shown}" Style="{StaticResource BadgeTextStyle}" /></Border>
                  </Grid>
                  <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="155" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <ComboBox ItemsSource="{Binding TimelineScopes}" SelectedItem="{Binding SelectedTimelineScope}" automation:AutomationProperties.Name="Timeline event filter" automation:AutomationProperties.AutomationId="Overview.TimelineFilter" />
                    <TextBlock Grid.Column="1" Text="{Binding TimelineFilterSummary}" Style="{StaticResource SubtleStyle}" VerticalAlignment="Center" Margin="10,0,0,0" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding VisibleTimelineEvents}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,9">
                          <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><WrapPanel><TextBlock Text="{Binding Source}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" /><TextBlock Text="  " /><TextBlock Text="{Binding Title}" FontWeight="SemiBold" /></WrapPanel><TextBlock Text="{Binding Message}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,0" /></StackPanel><TextBlock Grid.Column="1" Text="{Binding Timestamp}" Style="{StaticResource SubtleStyle}" Margin="10,0,0,0" VerticalAlignment="Top" /></Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="No events match this filter yet." Margin="0,10,0,0">
                    <TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasVisibleTimelineEvents}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                  </TextBlock>
                </StackPanel>
                </Border>
              </local:AdaptiveUniformGrid>

              <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,12,0,0">
              <StackPanel>
                <Grid>
                  <StackPanel>
                    <TextBlock Text="Sensor comparison" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Overlay up to four normalized recent trends. Use the native values and units in the legend; normalization compares movement, not magnitudes." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,3,0,0" />
                  </StackPanel>
                  <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4">
                    <TextBlock Text="{Binding MonitoringComparisonSensorCount, StringFormat={}{0}/4 series}" Style="{StaticResource BadgeTextStyle}" />
                  </Border>
                </Grid>
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="260" /></Grid.ColumnDefinitions>
                  <Border Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,16,0">
                    <sp:WpfPlot x:Name="ComparisonPlot" Height="140"
                                automation:AutomationProperties.Name="Sensor comparison chart"
                                automation:AutomationProperties.AutomationId="Overview.ComparisonChart" />
                  </Border>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="ADD LIVE SENSOR" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <ComboBox ItemsSource="{Binding MonitoringTrends}" SelectedItem="{Binding SelectedMonitoringComparisonTrend}" automation:AutomationProperties.Name="Sensor to add to comparison" automation:AutomationProperties.AutomationId="Overview.ComparisonSensor"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                    <WrapPanel Margin="0,8,0,4"><Button Content="Add" Command="{Binding AddMonitoringComparisonSensorCommand}" Margin="0,0,8,8" automation:AutomationProperties.Name="Add sensor to comparison" automation:AutomationProperties.AutomationId="Overview.AddComparison" /><Button Content="Save selection" Command="{Binding SaveMonitoringComparisonLayoutCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,8" automation:AutomationProperties.Name="Save sensor comparison" automation:AutomationProperties.AutomationId="Overview.SaveComparison" /></WrapPanel>
                    <TextBlock Text="{Binding MonitoringComparisonStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" automation:AutomationProperties.LiveSetting="Polite" />
                  </StackPanel>
                </Grid>
                <ItemsControl ItemsSource="{Binding MonitoringComparisonSeries}" Margin="0,10,0,0">
                  <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource InsetCardStyle}" Padding="9" Margin="0,0,8,8" MinWidth="210">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="{Binding Latest}" Margin="0,2,0,0" /><TextBlock Text="{Binding Range}" Style="{StaticResource SubtleStyle}" Margin="0,2,0,0" /></StackPanel><Button Grid.Column="1" Content="Remove" Command="{Binding DataContext.RemoveMonitoringComparisonSensorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource GhostButtonStyle}" VerticalAlignment="Center" automation:AutomationProperties.Name="Remove comparison sensor" /></Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Add live sensors to compare recent movement." Margin="0,3,0,0">
                  <TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding MonitoringComparisonSensorCount}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
              </StackPanel>
              </Border>
              </StackPanel>
            </Grid>

          </StackPanel>
        </ScrollViewer>

        <!-- Profiles -->
        <ScrollViewer x:Name="ProfilesPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <Border Style="{StaticResource CardStyle}" Background="{StaticResource AccentSoftBrush}" BorderBrush="#31557F" Padding="18">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Width="34" Height="34" CornerRadius="9" Background="#203D60" VerticalAlignment="Top">
                  <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="Stock-safe by default" FontWeight="SemiBold" FontSize="15" />
                  <TextBlock Text="Built-in profiles contain no above-stock CPU or GPU values. Every transition is validated and journalled before a write is attempted." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
              </Grid>
            </Border>

            <TextBlock Text="AVAILABLE PROFILES" Style="{StaticResource EyebrowStyle}" Margin="2,7,0,9" />
            <ItemsControl ItemsSource="{Binding ProfileCards}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <local:AdaptiveUniformGrid MaximumColumns="3" MinimumColumns="1" MinimumItemWidth="260" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource CardStyle}" Padding="19" MinHeight="245">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource SurfaceRaisedBrush}">
                          <TextBlock Text="{Binding Glyph}" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="46" />
                          <TextBlock Text="{Binding Objective}" ToolTip="{Binding Objective}" Style="{StaticResource SubtleStyle}" Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="12" Padding="8,3" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                          <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource BadgeTextStyle}" />
                        </Border>
                      </Grid>
                      <StackPanel Grid.Row="1" Margin="0,16,0,16">
                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextTrimming="None" />
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="7" Padding="10,7" Margin="0,13,0,0">
                          <TextBlock Text="{Binding ActionSummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" />
                        </Border>
                      </StackPanel>
                      <Button Grid.Row="2"
                              Command="{Binding DataContext.ApplyProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Style="{StaticResource ProfileActionButtonStyle}"
                              HorizontalAlignment="Stretch"
                              automation:AutomationProperties.Name="Apply profile" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid x:Name="SimpleProfilesGuide" Style="{StaticResource SimpleOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,12,0,0">
                <StackPanel>
                  <TextBlock Text="Choose a daily profile" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="The cards above are the only profile actions shown in Simple mode. They are generated from the power schemes available on this PC and stay within stock-safe limits." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid x:Name="AdvancedProfileTools" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <StackPanel>
            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="360">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Transition policy" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Cooling is raised first, followed by power, CPU, GPU, cooling, and lighting. Read-back must pass before commit." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                  <TextBlock Text="Validation → Snapshot → Safe order → Verify → Commit" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <Grid>
                    <TextBlock Text="Profile library" Style="{StaticResource CardTitleStyle}" />
                    <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="8,3">
                      <TextBlock Text="Generated profiles enabled" Style="{StaticResource BadgeTextStyle}" />
                    </Border>
                  </Grid>
                  <TextBlock Text="A tuning result is saved only after its final screening and remains Provisional. Experimental profiles require both acknowledgements below before Apply is enabled." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,8,0,12" />
                  <CheckBox IsChecked="{Binding AdvancedWritesAcknowledged}" Content="I understand Experimental profile actions can crash or misconfigure unsupported hardware." Margin="0,0,0,8" />
                  <CheckBox IsChecked="{Binding ProfileDeviceAcknowledged}" Content="I reviewed and confirm the exact devices and controls listed by the profile." Margin="0,0,0,8" />
                  <CheckBox IsChecked="{Binding ManualVoltageAcknowledged}" automation:AutomationProperties.Name="Acknowledge Manual Only voltage actions" automation:AutomationProperties.AutomationId="Profiles.AcknowledgeManualVoltage">
                    <TextBlock Text="This session only: I explicitly permit Manual Only voltage actions for the confirmed devices. Never used by startup or automation." TextWrapping="Wrap" />
                  </CheckBox>
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
              <StackPanel>
                <TextBlock Text="MSI Afterburner profile import" Style="{StaticResource CardTitleStyle}" />
                <TextBlock Text="Reads a local CFG profile into a typed, clean-room preview. Unsupported settings are visible but never converted into commands; voltage and VF values remain Manual Only." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,12" />
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                  <StackPanel Margin="0,0,8,0"><TextBlock Text="CFG PATH" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding AfterburnerImportPath, UpdateSourceTrigger=PropertyChanged}" ToolTip="Example: C:\Program Files (x86)\MSI Afterburner\Profiles\..." automation:AutomationProperties.Name="MSI Afterburner profile path" automation:AutomationProperties.AutomationId="Profiles.AfterburnerPath" /></StackPanel>
                  <StackPanel Grid.Column="1"><TextBlock Text="SECTION" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding AfterburnerImportSection, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="MSI Afterburner profile section" automation:AutomationProperties.AutomationId="Profiles.AfterburnerSection" /></StackPanel>
                </Grid>
                <TextBlock Text="{Binding AfterburnerImportStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,10,0,4" automation:AutomationProperties.LiveSetting="Polite" />
                <TextBlock Text="{Binding AfterburnerImportSummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,10" />
                <WrapPanel>
                  <Button Content="Preview mapping" Command="{Binding PreviewAfterburnerImportCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.Name="Preview MSI Afterburner mapping" automation:AutomationProperties.AutomationId="Profiles.PreviewAfterburner" />
                  <Button Content="Save imported profile" Command="{Binding SaveAfterburnerImportCommand}" Margin="0,0,8,8" ToolTip="Saving never applies the profile." automation:AutomationProperties.Name="Save imported MSI Afterburner profile" automation:AutomationProperties.AutomationId="Profiles.SaveAfterburner" />
                </WrapPanel>
                <ItemsControl ItemsSource="{Binding AfterburnerImportPreview.Settings}" Margin="0,3,0,0">
                  <ItemsControl.ItemTemplate><DataTemplate><Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /><ColumnDefinition Width="120" /></Grid.ColumnDefinitions><TextBlock Text="{Binding SourceKey}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock Grid.Column="1" Text="{Binding Message}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" Margin="8,0" /><TextBlock Grid.Column="2" Text="{Binding State}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" /></Grid></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
              </StackPanel>
            </Grid>

          </StackPanel>
        </ScrollViewer>

        <!-- Cooling -->
        <ScrollViewer x:Name="CoolingPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <Border Style="{StaticResource CardStyle}" Padding="18">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource WarningSoftBrush}">
                  <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                  <TextBlock Text="Evidence-gated cooling control" FontWeight="SemiBold" FontSize="15" />
                  <TextBlock Text="Bounded adapters can run Experimental calibration after two explicit acknowledgements. Competing writers and controllers without reset semantics remain blocked." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="12" Padding="9,4" Background="{StaticResource WarningSoftBrush}" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1" VerticalAlignment="Top">
                  <TextBlock Text="EVIDENCE GATED" Style="{StaticResource BadgeTextStyle}" Foreground="{StaticResource WarningBrush}" />
                </Border>
              </Grid>
            </Border>

            <Grid x:Name="SimpleCoolingStatus" Style="{StaticResource SimpleOnlyPanelStyle}">
              <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="330" Margin="0,12,0,0">
                <Border Style="{StaticResource CardStyle}" Padding="18">
                  <StackPanel>
                    <TextBlock Text="Cooling status" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="{Binding CalibrationAvailabilityLabel}" FontWeight="SemiBold" Margin="0,7,0,4">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding CalibrationAvailabilityTone}" Value="Safe">
                              <Setter Property="Foreground" Value="{StaticResource SafeBrush}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CoolingCapabilities.Count, StringFormat={}{0} cooling controls detected}" Style="{StaticResource SubtleStyle}" />
                    <TextBlock Text="Simple mode keeps fan commissioning, calibration, curves, imports, and controller evidence out of the way. Firmware/default control remains the safe fallback." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,10,0,0" />
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="18">
                  <StackPanel>
                    <TextBlock Text="Always-on protection" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Three stale sensor polls request maximum cooling, firmware/default control, and a safety event. CPU fans and pumps cannot be stopped." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,7,0,0" />
                  </StackPanel>
                </Border>
              </local:AdaptiveUniformGrid>
            </Grid>

            <Grid x:Name="AdvancedCoolingWorkspace" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <StackPanel>
            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="380">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <Grid Margin="0,0,0,3">
                    <StackPanel>
                      <TextBlock Text="Cooling capabilities" Style="{StaticResource CardTitleStyle}" />
                      <TextBlock Text="Ownership, access state, and evidence" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4">
                      <TextBlock Text="{Binding CoolingCapabilities.Count, StringFormat={}{0} found}" Style="{StaticResource BadgeTextStyle}" />
                    </Border>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding CoolingCapabilities}" ItemTemplate="{StaticResource CapabilityTemplate}" />
                  <Border Margin="0,12,0,0">
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers><DataTrigger Binding="{Binding HasCoolingCapabilities}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                      </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="&#xE9CA;" FontFamily="{StaticResource IconFont}" FontSize="22" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                      <TextBlock Text="No controllable fans detected" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0" />
                      <TextBlock Text="Firmware control remains active." Style="{StaticResource MutedStyle}" HorizontalAlignment="Center" Margin="0,3,0,0" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <StackPanel>
                <Border Style="{StaticResource CardStyle}">
                  <StackPanel>
                    <TextBlock Text="Emergency policy" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Fail-safe behaviour is fixed and cannot be weakened by a profile." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,13" />
                    <Grid Margin="0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="1" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><TextBlock Grid.Column="1" Text="Three stale polls trigger 100% duty." /></Grid>
                    <Grid Margin="0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="2" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><TextBlock Grid.Column="1" Text="Firmware/default control is requested." /></Grid>
                    <Grid Margin="0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="3" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><TextBlock Grid.Column="1" Text="A safety event is raised and writes stop." /></Grid>
                  </StackPanel>
                </Border>
                <Border x:Name="CoolingCommissioningWizard" Style="{StaticResource CardStyle}">
                  <StackPanel>
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <TextBlock Text="Header commissioning" Style="{StaticResource CardTitleStyle}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                      <Border Grid.Column="1" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="8,3"><TextBlock Text="{Binding CommissioningStateLabel}" Style="{StaticResource BadgeTextStyle}" /></Border>
                    </Grid>
                    <TextBlock Text="Map one physical header at a time. The wizard stores the RPM pairing, explicit identity confirmation, bounded calibration result, and recovery state. It never permits CPU-fan or pump stop." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,7,0,12" />
                    <TextBlock Text="SAVED SESSION" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <ComboBox ItemsSource="{Binding FanCommissioningSessions}" SelectedItem="{Binding SelectedFanCommissioningSession}" automation:AutomationProperties.Name="Fan commissioning session" automation:AutomationProperties.AutomationId="Cooling.CommissioningSession">
                      <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding HeaderName}" /></DataTemplate></ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="KNOWN PHYSICAL CHASSIS HEADER" Style="{StaticResource EyebrowStyle}" Margin="0,10,0,5" />
                    <TextBox Text="{Binding CommissioningHeaderName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Physical fan header name" automation:AutomationProperties.AutomationId="Cooling.HeaderName" />
                    <TextBlock Text="Check the motherboard wiring first. Enter a label such as CHA_FAN1; generic labels such as Fan #1 cannot be pulsed." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                    <TextBlock Text="NOTES (OPTIONAL)" Style="{StaticResource EyebrowStyle}" Margin="0,10,0,5" />
                    <TextBox Text="{Binding CommissioningNotes, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Fan commissioning notes" automation:AutomationProperties.AutomationId="Cooling.CommissioningNotes" />
                    <CheckBox IsChecked="{Binding CommissioningHeaderConfirmed}" Margin="0,11,0,0" automation:AutomationProperties.AutomationId="Cooling.ConfirmHeader">
                      <TextBlock Text="I visually confirmed the selected header changes the intended physical fan." TextWrapping="Wrap" />
                    </CheckBox>
                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,10,0,0">
                      <StackPanel>
                        <TextBlock Text="COMMISSIONING PREFLIGHT" Style="{StaticResource EyebrowStyle}" />
                        <TextBlock Text="{Binding CommissioningTargetSummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        <CheckBox IsChecked="{Binding CommissioningObserverReady}" Margin="0,9,0,0" automation:AutomationProperties.Name="Commissioning observer ready" automation:AutomationProperties.AutomationId="Cooling.ObserverReady">
                          <TextBlock Text="A person can see the intended physical fan during the two-second pulse." TextWrapping="Wrap" />
                        </CheckBox>
                        <TextBlock Text="{Binding CommissioningPreflight}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,7,0,0" automation:AutomationProperties.LiveSetting="Polite" />
                      </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding CommissioningObservation}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,9,0,11" automation:AutomationProperties.LiveSetting="Polite" />
                    <WrapPanel>
                      <Button Content="Start setup" Command="{Binding BeginFanCommissioningCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Cooling.BeginCommissioning" />
                      <Button Content="Pulse header (2 s)" Command="{Binding PulseFanCommissioningCommand}" Margin="0,0,8,8" ToolTipService.ShowOnDisabled="True" ToolTip="{Binding CommissioningPreflight}" automation:AutomationProperties.AutomationId="Cooling.PulseCommissioning" />
                      <Button Content="Run elevated diagnostic" Command="{Binding RunInteractiveFanPreflightCommand}" Margin="0,0,8,8" ToolTip="Requests UAC and runs adapter Prepare only. It never sends a fan command or enables the service write path." automation:AutomationProperties.AutomationId="Cooling.RunElevatedDiagnostic" />
                      <Button Content="Observe" Command="{Binding ObserveFanCommissioningCommand}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Cooling.ObserveCommissioning" />
                      <Button Content="Confirm header" Command="{Binding ConfirmFanCommissioningCommand}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Cooling.ConfirmCommissioning" />
                      <Button Content="Save report" Command="{Binding CompleteFanCommissioningCommand}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Cooling.CompleteCommissioning" />
                      <Button Content="Create adaptive curve" Command="{Binding CreateAdaptiveCoolingProfileCommand}" Margin="0,0,8,8" ToolTipService.ShowOnDisabled="True" ToolTip="{Binding AdaptiveCoolingProfileEligibilityReason}" automation:AutomationProperties.Name="Create adaptive nonzero cooling curve" automation:AutomationProperties.AutomationId="Cooling.CreateAdaptiveCurve" />
                      <Button Content="Cancel" Command="{Binding CancelFanCommissioningCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Cooling.CancelCommissioning" />
                      <Button Content="Recover default" Command="{Binding RecoverFanCommissioningCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,8" ToolTip="Available only when a prior recovery did not complete." automation:AutomationProperties.AutomationId="Cooling.RecoverCommissioning" />
                    </WrapPanel>
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                  <StackPanel>
                    <Grid>
                      <TextBlock Text="Fan calibration" Style="{StaticResource CardTitleStyle}" />
                      <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="8,3"><TextBlock Text="{Binding CalibrationAvailabilityLabel}" Style="{StaticResource BadgeTextStyle}" /></Border>
                    </Grid>
                    <TextBlock Text="Learns this output's duty-to-RPM response at every 5 percentage-point step. A fan that keeps spinning at the controller minimum can use a measured nonzero floor; zero-RPM requires two or three complete stop/restart cycles." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,8,0,13" />
                    <TextBlock Text="CONTROL TARGET" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <ComboBox ItemsSource="{Binding CalibrationTargets}" SelectedItem="{Binding SelectedCalibrationTarget}" automation:AutomationProperties.Name="Calibration control target" automation:AutomationProperties.AutomationId="Cooling.CalibrationTarget">
                      <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                    </ComboBox>
                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,10,0,0">
                      <StackPanel>
                        <TextBlock Text="OUTPUT SAFETY ROLE" Style="{StaticResource EyebrowStyle}" />
                        <TextBlock Text="Store a physical role when a generic controller name is misleading. This is a policy-only change: it never sends a fan command." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,9" />
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="ROLE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                            <ComboBox ItemsSource="{Binding CoolingOutputRoles}" SelectedItem="{Binding SelectedCoolingOutputRole}" automation:AutomationProperties.Name="Cooling output safety role" automation:AutomationProperties.AutomationId="Cooling.OutputRole" />
                          </StackPanel>
                          <StackPanel Grid.Column="2">
                            <TextBlock Text="PHYSICAL HEADER" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                            <TextBox Text="{Binding CoolingOutputHeaderName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Cooling output physical header" automation:AutomationProperties.AutomationId="Cooling.OutputHeader" />
                          </StackPanel>
                        </Grid>
                        <CheckBox IsChecked="{Binding RemoveCoolingSafetyProtectionAcknowledged}" Margin="0,9,0,0" automation:AutomationProperties.AutomationId="Cooling.AcknowledgeRemoveProtection">
                          <TextBlock Text="I understand changing a stored CPU-fan or pump role removes its extra service protection." TextWrapping="Wrap" />
                        </CheckBox>
                        <TextBlock Text="{Binding CoolingOutputRoleStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,8,0,9" automation:AutomationProperties.LiveSetting="Polite" />
                        <Button Content="Save output role" Command="{Binding SaveCoolingOutputAssignmentCommand}" HorizontalAlignment="Left" automation:AutomationProperties.AutomationId="Cooling.SaveOutputRole" />
                      </StackPanel>
                    </Border>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding SelectedCalibrationTarget.State}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1" Text="{Binding SelectedCalibrationTarget.Range}" Style="{StaticResource SubtleStyle}" />
                    </Grid>
                    <TextBlock Text="{Binding CalibrationEligibilityReason}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,12" />
                    <CheckBox IsChecked="{Binding AdvancedWritesAcknowledged}" Margin="0,0,0,8" automation:AutomationProperties.AutomationId="Cooling.AcknowledgeExperimental">
                      <TextBlock Text="I understand Experimental writes can crash or misconfigure unsupported hardware." TextWrapping="Wrap" />
                    </CheckBox>
                    <CheckBox IsChecked="{Binding CalibrationDeviceAcknowledged}" Margin="0,0,0,8" automation:AutomationProperties.AutomationId="Cooling.AcknowledgeDevice" automation:AutomationProperties.Name="I confirm this exact calibration target">
                      <TextBlock Text="{Binding SelectedCalibrationTarget.DisplayName, StringFormat=I confirm this exact target: {0}}" TextWrapping="Wrap" />
                    </CheckBox>
                    <CheckBox IsChecked="{Binding AllowCaseFanStop}" IsEnabled="{Binding CanAllowCaseFanStop}" Margin="0,0,0,13" automation:AutomationProperties.AutomationId="Cooling.AllowFanStop">
                      <TextBlock Text="Allow this GPU or confirmed case fan to stop for restart testing (never CPU fans or pumps). Unverified targets use a nonzero 10% safety band." TextWrapping="Wrap" />
                    </CheckBox>
                    <Border Margin="0,0,0,13">
                      <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource InsetCardStyle}">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers><DataTrigger Binding="{Binding IsAdvancedLab}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                        </Style>
                      </Border.Style>
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="SETTLING TIME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                          <ComboBox ItemsSource="{Binding CalibrationSettlingOptions}" SelectedItem="{Binding CalibrationSettlingSeconds}" automation:AutomationProperties.Name="Calibration settling time in seconds" automation:AutomationProperties.AutomationId="Cooling.SettlingSeconds" />
                          <TextBlock Text="Stable RPM sampling starts after this delay." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                          <TextBlock Text="RESTART CYCLES" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                          <ComboBox ItemsSource="{Binding CalibrationRestartCycleOptions}" SelectedItem="{Binding CalibrationRestartCycleCount}" automation:AutomationProperties.Name="Required restart verification cycles" automation:AutomationProperties.AutomationId="Cooling.RestartCycles" />
                          <TextBlock Text="Every cycle must stop and restart at the measured duty." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                      </Grid>
                    </Border>
                    <WrapPanel>
                      <Button Content="Start calibration" Command="{Binding StartCalibrationCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" ToolTipService.ShowOnDisabled="True" ToolTip="{Binding CalibrationEligibilityReason}" automation:AutomationProperties.AutomationId="Cooling.StartCalibration" />
                      <Button Content="Abort and restore" Command="{Binding AbortOperationCommand}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Cooling.AbortCalibration" />
                    </WrapPanel>
                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,8,0,0">
                      <StackPanel>
                        <Grid><TextBlock Text="{Binding OperationTitle}" FontWeight="SemiBold" /><TextBlock Text="{Binding OperationProgressText}" HorizontalAlignment="Right" Style="{StaticResource SubtleStyle}" /></Grid>
                        <TextBlock Text="{Binding OperationMessage}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,9" />
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding OperationProgress, Mode=OneWay}" Height="5" Foreground="{StaticResource AccentBrush}" Background="{StaticResource BorderBrush}" />
                        <TextBlock Text="{Binding OperationError}" Foreground="{StaticResource CriticalBrush}" TextWrapping="Wrap" Margin="0,8,0,0">
                          <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasOperationError}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                        </TextBlock>
                      </StackPanel>
                    </Border>
                    <Border Margin="0,8,0,0" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.Name="Calibration result">
                      <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource InsetCardStyle}">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers><DataTrigger Binding="{Binding HasCalibrationResult}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                        </Style>
                      </Border.Style>
                      <StackPanel>
                        <TextBlock Text="Per-output calibration result" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CalibrationResultSummary}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        <TextBlock Text="{Binding CalibrationOperatingEnvelopeSummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CalibrationStabilitySummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>
            </local:AdaptiveUniformGrid>

            <Border Margin="0,12,0,0">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAdvancedLab}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <Grid>
                  <StackPanel>
                    <TextBlock Text="Manual curve studio" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Fan Control-style temperature-to-duty points for one calibrated output. RigPilot retains the measured nonzero floor and requires the final point to reach that controller's maximum." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="8,3"><TextBlock Text="ADVANCED" Style="{StaticResource BadgeTextStyle}" /></Border>
                </Grid>
                <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="300" Margin="0,13,0,0">
                  <StackPanel Margin="0,0,10,10">
                    <TextBlock Text="CURVE NAME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <TextBox Text="{Binding CustomCoolingCurveName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Manual cooling curve name" automation:AutomationProperties.AutomationId="Cooling.CustomCurveName" />
                    <TextBlock Text="TEMPERATURE : DUTY POINTS" Style="{StaticResource EyebrowStyle}" Margin="0,11,0,5" />
                    <TextBox Text="{Binding CustomCoolingCurvePoints, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="106" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" ToolTip="One point per line, for example: 35:25" automation:AutomationProperties.Name="Manual cooling curve points" automation:AutomationProperties.AutomationId="Cooling.CustomCurvePoints" />
                    <TextBlock Text="Use two to eight strictly increasing points. Values use °C:% and must stay above this output's measured floor." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                  </StackPanel>
                  <StackPanel Margin="0,0,0,10">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="RISE HYSTERESIS (°C)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                        <TextBox Text="{Binding CustomCoolingCurveHysteresisUpText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Manual cooling curve rise hysteresis" automation:AutomationProperties.AutomationId="Cooling.CustomCurveHysteresisUp" />
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Text="FALL HYSTERESIS (°C)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                        <TextBox Text="{Binding CustomCoolingCurveHysteresisDownText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Manual cooling curve fall hysteresis" automation:AutomationProperties.AutomationId="Cooling.CustomCurveHysteresisDown" />
                      </StackPanel>
                    </Grid>
                    <Grid Margin="0,11,0,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="RISE RESPONSE (S)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                        <TextBox Text="{Binding CustomCoolingCurveResponseUpSecondsText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Manual cooling curve rise response time" automation:AutomationProperties.AutomationId="Cooling.CustomCurveResponseUp" />
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Text="FALL RESPONSE (S)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                        <TextBox Text="{Binding CustomCoolingCurveResponseDownSecondsText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Manual cooling curve fall response time" automation:AutomationProperties.AutomationId="Cooling.CustomCurveResponseDown" />
                      </StackPanel>
                    </Grid>
                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,12,0,0">
                      <StackPanel>
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <TextBlock Text="CURVE PREVIEW" Style="{StaticResource EyebrowStyle}" />
                          <TextBlock Grid.Column="1" Text="{Binding CustomCoolingCurveAxisLabel}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" />
                        </Grid>
                        <Viewbox Stretch="Fill" StretchDirection="DownOnly" Height="120" HorizontalAlignment="Left" Margin="0,8,0,0">
                          <Canvas Width="320" Height="120">
                            <Line X1="0" Y1="12" X2="320" Y2="12" Stroke="{StaticResource BorderBrush}" StrokeThickness="1" />
                            <Line X1="0" Y1="60" X2="320" Y2="60" Stroke="{StaticResource BorderBrush}" StrokeThickness="1" StrokeDashArray="3,3" />
                            <Line X1="0" Y1="108" X2="320" Y2="108" Stroke="{StaticResource BorderBrush}" StrokeThickness="1" />
                            <Polyline Points="{Binding CustomCoolingCurvePreviewGeometry}" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                          </Canvas>
                        </Viewbox>
                        <TextBlock Text="{Binding CustomCoolingCurvePreview}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,7,0,0" />
                      </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding CustomCoolingCurveEligibilityReason}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,10,0,10" automation:AutomationProperties.LiveSetting="Polite" />
                    <Button Content="Save inactive curve" Command="{Binding SaveCustomCoolingCurveCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" ToolTipService.ShowOnDisabled="True" ToolTip="{Binding CustomCoolingCurveEligibilityReason}" automation:AutomationProperties.Name="Save manual cooling curve" automation:AutomationProperties.AutomationId="Cooling.SaveCustomCurve" />
                  </StackPanel>
                </local:AdaptiveUniformGrid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
              <StackPanel>
                <TextBlock Text="Fan Control configuration import" Style="{StaticResource CardTitleStyle}" />
                <TextBlock Text="Paste one explicit mapping per line: source=RigPilotId. Previewing does not write a fan, and saving stores a graph only; an approved profile must still select it." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,12" />
                <TextBlock Text="FAN CONTROL JSON PATH" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                <TextBox Text="{Binding FanControlImportPath, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Fan Control configuration path" automation:AutomationProperties.AutomationId="Cooling.FanControlPath" />
                <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="290" Margin="0,10,0,0">
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="SENSOR MAPPINGS" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding FanControlSensorMappings, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="62" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" ToolTip="Example: CPU Package=sensor.cpu.package" automation:AutomationProperties.Name="Fan Control sensor mappings" automation:AutomationProperties.AutomationId="Cooling.FanControlSensorMappings" /></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="CONTROL MAPPINGS" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding FanControlControlMappings, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="62" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" ToolTip="Example: CHA_FAN1=fan.nct6798d.cha1" automation:AutomationProperties.Name="Fan Control control mappings" automation:AutomationProperties.AutomationId="Cooling.FanControlControlMappings" /></StackPanel>
                </local:AdaptiveUniformGrid>
                <TextBlock Text="{Binding FanControlImportStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,4" automation:AutomationProperties.LiveSetting="Polite" />
                <TextBlock Text="{Binding FanControlImportSummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,10" />
                <WrapPanel>
                  <Button Content="Preview graph" Command="{Binding PreviewFanControlImportCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.Name="Preview Fan Control graph" automation:AutomationProperties.AutomationId="Cooling.PreviewFanControl" />
                  <Button Content="Save imported graph" Command="{Binding SaveFanControlImportCommand}" Margin="0,0,8,8" ToolTip="Saving does not activate a curve." automation:AutomationProperties.Name="Save imported Fan Control graph" automation:AutomationProperties.AutomationId="Cooling.SaveFanControl" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
              <StackPanel>
                <Grid><StackPanel><TextBlock Text="Cooling qualification evidence" Style="{StaticResource CardTitleStyle}" /><TextBlock Text="Header identity, calibration, restart, emergency timing, suspend/resume, and firmware-default recovery are tracked separately." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel><Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4"><TextBlock Text="{Binding CoolingQualificationReports.Count, StringFormat={}{0} reports}" Style="{StaticResource BadgeTextStyle}" /></Border></Grid>
                <ItemsControl ItemsSource="{Binding CoolingQualificationReports}" Margin="0,10,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                          <Grid><TextBlock Text="{Binding HeaderName}" FontWeight="SemiBold" /><TextBlock Text="{Binding CommissioningState}" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" /></Grid>
                          <TextBlock Text="{Binding Summary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,7" />
                          <ItemsControl ItemsSource="{Binding Steps}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}" /><TextBlock Grid.Column="1" Text="{Binding State}" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" Margin="8,0" /><TextBlock Grid.Column="2" Text="{Binding Evidence}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" /></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No commissioning evidence is stored yet. Start by confirming one header; calibration and restart evidence do not become pass states automatically." Margin="0,8,0,0">
                  <TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding CoolingQualificationReports.Count}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
              </StackPanel>
            </Border>
              </StackPanel>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <!-- Performance -->
        <ScrollViewer x:Name="PerformancePage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <Border Style="{StaticResource CardStyle}" Background="{StaticResource AccentSoftBrush}" BorderBrush="#31557F" Padding="18">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Border Width="34" Height="34" CornerRadius="9" Background="#203D60">
                  <TextBlock Text="&#xE945;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                  <TextBlock Text="Evidence-gated performance controls" FontWeight="SemiBold" FontSize="15" />
                  <TextBlock Text="The tuning engine accepts only bounded numeric controls with read-back and reset. Experimental adapters require two acknowledgements; missing vendor endpoints remain absent." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="12" Padding="9,4" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                  <TextBlock Text="EVIDENCE GATED" Style="{StaticResource BadgeTextStyle}" />
                </Border>
              </Grid>
            </Border>

            <Grid x:Name="SimplePerformanceStatus" Style="{StaticResource SimpleOnlyPanelStyle}">
              <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="330" Margin="0,12,0,0">
                <Border Style="{StaticResource CardStyle}" Padding="18">
                  <StackPanel>
                    <TextBlock Text="Performance status" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="{Binding TuneAvailabilityLabel}" FontWeight="SemiBold" Margin="0,7,0,4">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding TuneAvailabilityTone}" Value="Safe">
                              <Setter Property="Foreground" Value="{StaticResource SafeBrush}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding PerformanceCapabilities.Count, StringFormat={}{0} hardware controls assessed}" Style="{StaticResource SubtleStyle}" />
                    <TextBlock Text="Daily profile changes stay on the Profiles page. Tuning targets, bounds, screening, and qualification work remain in Advanced Lab." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,10,0,0" />
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="18">
                  <StackPanel>
                    <TextBlock Text="Safe operating policy" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="RigPilot does not automatically raise voltage. A hardware control remains unavailable until its exact adapter proves bounds, read-back, reset, and fault handling." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,7,0,0" />
                  </StackPanel>
                </Border>
              </local:AdaptiveUniformGrid>
            </Grid>

            <Grid x:Name="AdvancedPerformanceWorkspace" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <StackPanel>
            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="380">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <Grid>
                    <StackPanel>
                      <TextBlock Text="CPU, GPU, and power" Style="{StaticResource CardTitleStyle}" />
                      <TextBlock Text="Exact capability reasons from installed adapters" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4">
                      <TextBlock Text="{Binding PerformanceCapabilities.Count, StringFormat={}{0} found}" Style="{StaticResource BadgeTextStyle}" />
                    </Border>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding PerformanceCapabilities}" ItemTemplate="{StaticResource CapabilityTemplate}" />
                  <Border Margin="0,12,0,0">
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers><DataTrigger Binding="{Binding HasPerformanceCapabilities}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                      </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="&#xE945;" FontFamily="{StaticResource IconFont}" FontSize="22" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                      <TextBlock Text="No performance controls exposed" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0" />
                      <TextBlock Text="Monitoring remains available on Overview." Style="{StaticResource MutedStyle}" HorizontalAlignment="Center" Margin="0,3,0,0" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
              <StackPanel>
                <Border Style="{StaticResource CardStyle}">
                  <StackPanel>
                    <TextBlock Text="Auto-tuning status" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="{Binding TuneAvailabilityLabel}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" Margin="0,7,0,5" />
                    <TextBlock Text="Each operation searches one cooling, CPU, or GPU control. Voltage controls are rejected, the final screen runs for 10 minutes, and a boot sentinel prevents candidate reapplication." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" />
                    <TextBlock Text="CONTROL TARGET" Style="{StaticResource EyebrowStyle}" Margin="0,15,0,5" />
                    <ComboBox ItemsSource="{Binding TuneTargets}" SelectedItem="{Binding SelectedTuneTarget}" automation:AutomationProperties.Name="Performance tuning target" automation:AutomationProperties.AutomationId="Performance.TuneTarget">
                      <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                    </ComboBox>
                    <Grid Margin="0,10,0,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <StackPanel Margin="0,0,6,0"><TextBlock Text="OBJECTIVE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding TuneObjectives}" SelectedItem="{Binding SelectedTuneObjective}" automation:AutomationProperties.Name="Tuning objective" automation:AutomationProperties.AutomationId="Performance.TuneObjective" /></StackPanel>
                      <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="TEMPERATURE CEILING (°C)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding TuneTemperatureCeilingText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Tuning temperature ceiling in degrees Celsius" automation:AutomationProperties.AutomationId="Performance.TemperatureCeiling" /></StackPanel>
                    </Grid>
                    <TextBlock Text="OPTIONAL POWER CEILING (W)" Style="{StaticResource EyebrowStyle}" Margin="0,10,0,5" />
                    <TextBox Text="{Binding TunePowerCeilingText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Optional tuning power ceiling in watts" automation:AutomationProperties.AutomationId="Performance.PowerCeiling" />
                    <TextBlock Text="{Binding TuneEligibilityReason}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,7,0,12" />
                    <CheckBox IsChecked="{Binding AdvancedWritesAcknowledged}" Content="I understand Experimental writes can crash or misconfigure unsupported hardware." Margin="0,0,0,8" />
                    <CheckBox IsChecked="{Binding TuneDeviceAcknowledged}" Margin="0,0,0,13" automation:AutomationProperties.Name="I confirm this exact tuning target">
                      <TextBlock Text="{Binding SelectedTuneTarget.DisplayName, StringFormat=I confirm this exact target: {0}}" TextWrapping="Wrap" />
                    </CheckBox>
                    <WrapPanel>
                      <Button Content="Start 10-minute tune" Command="{Binding StartTuneCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" ToolTipService.ShowOnDisabled="True" ToolTip="{Binding TuneEligibilityReason}" />
                      <Button Content="Abort and restore" Command="{Binding AbortOperationCommand}" Margin="0,0,8,8" />
                    </WrapPanel>
                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,8,0,0">
                      <StackPanel>
                        <Grid><TextBlock Text="{Binding OperationTitle}" FontWeight="SemiBold" /><TextBlock Text="{Binding OperationProgressText}" HorizontalAlignment="Right" Style="{StaticResource SubtleStyle}" /></Grid>
                        <TextBlock Text="{Binding OperationMessage}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,9" />
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding OperationProgress, Mode=OneWay}" Height="5" Foreground="{StaticResource AccentBrush}" Background="{StaticResource BorderBrush}" />
                        <TextBlock Text="{Binding OperationError}" Foreground="{StaticResource CriticalBrush}" TextWrapping="Wrap" Margin="0,8,0,0">
                          <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasOperationError}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                        </TextBlock>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                  <StackPanel>
                    <TextBlock Text="Screening language" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="A candidate that completes the final workload is labelled “Passed 10-minute screening,” never “stable.” Provisional status requires active-use, calendar-time, and cold-boot evidence." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,7,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </local:AdaptiveUniformGrid>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
              <StackPanel>
                <Grid><StackPanel><TextBlock Text="Exact-device tuning qualification" Style="{StaticResource CardTitleStyle}" /><TextBlock Text="Ryzen 5800X and RTX 3090 controls stay unavailable until identity, bounds, apply/read-back, reset, and fault screening all have exact evidence." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel><Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4"><TextBlock Text="{Binding TuningQualificationPlans.Count, StringFormat={}{0} plans}" Style="{StaticResource BadgeTextStyle}" /></Border></Grid>
                <ItemsControl ItemsSource="{Binding TuningQualificationPlans}" Margin="0,10,0,0">
                  <ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,8"><StackPanel><Grid><TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" /><StackPanel HorizontalAlignment="Right"><TextBlock Text="{Binding ReadinessLabel}" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Right" /><TextBlock Text="{Binding PassedStepCount, StringFormat={}{0} evidence gates passed}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,0" /></StackPanel></Grid><TextBlock Text="{Binding Summary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,7" /><ItemsControl ItemsSource="{Binding Steps}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}" /><TextBlock Grid.Column="1" Text="{Binding State}" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" /><TextBlock Grid.Column="2" Text="{Binding Evidence}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Guidance}" /></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
              </StackPanel>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <!-- Lighting -->
        <ScrollViewer x:Name="LightingPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="380">
              <Border Style="{StaticResource CardStyle}" Padding="22">
                <StackPanel>
                  <Grid>
                    <StackPanel Orientation="Horizontal">
                      <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource AccentSoftBrush}">
                        <TextBlock Text="&#xE706;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="OpenRGB bridge" Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Text="Local user-session SDK integration" Style="{StaticResource MutedStyle}" Margin="0,2,0,0" />
                      </StackPanel>
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="12" Padding="9,4" Background="{StaticResource SurfaceRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                      <TextBlock Text="{Binding OpenRgbConnectionLabel}" Style="{StaticResource BadgeTextStyle}" />
                    </Border>
                  </Grid>
                  <TextBlock Text="RigPilot connects only to 127.0.0.1:6742 after explicit opt-in. The service never opens this socket, and OpenRGB is never bundled." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,18,0,12" />
                  <CheckBox IsChecked="{Binding OpenRgbEnabled}" Content="Enable the local OpenRGB SDK bridge." />
                  <Separator />
                  <TextBlock Text="{Binding OpenRgbStatus}" Foreground="{StaticResource SafeBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding LightingConflictReason}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,12" />
                  <Button Content="Test local SDK server" Command="{Binding ProbeOpenRgbCommand}" HorizontalAlignment="Left" ToolTipService.ShowOnDisabled="True" ToolTip="Enable the bridge and close competing lighting writers first." />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}" Padding="22">
                <StackPanel>
                  <TextBlock Text="Static lighting" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="The bridge negotiates protocol support, enumerates exact controllers, enters custom mode, then updates every reported LED." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,14" />
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,6,0"><TextBlock Text="COLOUR (#RRGGBB)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding OpenRgbColour, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="OpenRGB colour hexadecimal value" automation:AutomationProperties.AutomationId="Lighting.OpenRgbColour" /></StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="BRIGHTNESS (%)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding OpenRgbBrightnessText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="OpenRGB brightness percentage" automation:AutomationProperties.AutomationId="Lighting.OpenRgbBrightness" /></StackPanel>
                  </Grid>
                  <WrapPanel Margin="0,14,0,0">
                    <Button Content="Apply static colour" Command="{Binding ApplyOpenRgbCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" />
                    <Button Content="Turn lighting off" Command="{Binding TurnOffOpenRgbCommand}" Margin="0,0,8,8" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <Grid x:Name="SimpleLightingGuide" Style="{StaticResource SimpleOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,12,0,0">
                <StackPanel>
                  <TextBlock Text="Daily lighting controls" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Simple mode keeps the local OpenRGB bridge and one static scene available. Device routes, LampArray layout editing, effect-host detail, and direct-controller qualification are in Advanced Lab." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid x:Name="AdvancedLightingWorkspace" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <StackPanel>
            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0" automation:AutomationProperties.Name="RGB compatibility routing matrix" automation:AutomationProperties.AutomationId="Lighting.RouteMatrix">
              <StackPanel>
                <Grid>
                  <StackPanel>
                    <TextBlock Text="RGB compatibility routing" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Every detected RGB family is routed through Windows Dynamic Lighting, a user-installed local OpenRGB server, a qualified adapter, or read-only qualification. A manufacturer name alone never enables a proprietary USB write." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4" Margin="16,0,0,0">
                    <TextBlock Text="{Binding RgbReadyRouteCount, StringFormat={}{0} ready}" Style="{StaticResource BadgeTextStyle}" />
                  </Border>
                </Grid>
                <TextBlock Text="{Binding RgbCompatibilitySummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,12,0,10" />
                <ItemsControl ItemsSource="{Binding RgbRouteAssessments}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,8">
                        <StackPanel>
                          <Grid>
                            <StackPanel>
                              <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource SubtleStyle}" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right">
                              <TextBlock Text="{Binding StateLabel}" FontWeight="SemiBold" HorizontalAlignment="Right">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding StateTone}" Value="Safe"><Setter Property="Foreground" Value="{StaticResource SafeBrush}" /></DataTrigger>
                                      <DataTrigger Binding="{Binding StateTone}" Value="Critical"><Setter Property="Foreground" Value="{StaticResource CriticalBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>
                              <TextBlock Text="{Binding RouteLabel}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,0" />
                            </StackPanel>
                          </Grid>
                          <TextBlock Text="{Binding Summary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,8,0,5" />
                          <TextBlock Text="{Binding EvidenceBoundary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,5" />
                          <TextBlock Text="{Binding NextAction}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Margin="0,2,0,0">
                  <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers><DataTrigger Binding="{Binding HasRgbRouteAssessments}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                    </Style>
                  </Border.Style>
                  <StackPanel HorizontalAlignment="Center"><TextBlock Text="No RGB route data yet" FontWeight="SemiBold" /><TextBlock Text="Refresh hardware inventory, then probe Windows Dynamic Lighting or the local OpenRGB bridge." Style="{StaticResource MutedStyle}" Margin="0,4,0,0" /></StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="380">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <Grid>
                    <StackPanel><TextBlock Text="Windows Dynamic Lighting" Style="{StaticResource CardTitleStyle}" /><TextBlock Text="Native LampArray discovery and per-lamp zones" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" /></StackPanel>
                    <Border HorizontalAlignment="Right" Background="{StaticResource AccentSoftBrush}" CornerRadius="12" Padding="9,4"><TextBlock Text="{Binding DynamicLightingDeviceCount, StringFormat={}{0} devices}" Style="{StaticResource BadgeTextStyle}" /></Border>
                  </Grid>
                  <TextBlock Text="{Binding DynamicLightingStatus}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextTrimming="None" Margin="0,14,0,12" />
                  <Button Content="Probe Dynamic Lighting" Command="{Binding ProbeDynamicLightingCommand}" HorizontalAlignment="Left" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Physical layout editor" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Build explicit controller/channel zones from Windows-reported lamp indices. A saved layout can be reused by game bundles and applied through Windows Dynamic Lighting." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,12" />
                  <TextBlock Text="DYNAMIC LIGHTING DEVICE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                  <ComboBox ItemsSource="{Binding DynamicLightingDevices}" SelectedItem="{Binding SelectedDynamicLightingDevice}" automation:AutomationProperties.Name="Dynamic Lighting layout device" automation:AutomationProperties.AutomationId="Lighting.LayoutDevice">
                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                  </ComboBox>
                  <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="150" Margin="0,11,0,0">
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="ZONE NAME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding LightingZoneName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Physical lighting zone name" automation:AutomationProperties.AutomationId="Lighting.ZoneName" /></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="LED INDICES" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding LightingZoneLedIndices, UpdateSourceTrigger=PropertyChanged}" ToolTip="Example: 0-15, 20, 22-24" automation:AutomationProperties.Name="Physical lighting zone LED indices" automation:AutomationProperties.AutomationId="Lighting.ZoneIndices" /></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="X / Y" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><StackPanel Orientation="Horizontal"><TextBox Width="64" Text="{Binding LightingZoneXText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Physical lighting zone X position" /><TextBox Width="64" Margin="7,0,0,0" Text="{Binding LightingZoneYText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Physical lighting zone Y position" /></StackPanel></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="WIDTH / HEIGHT" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><StackPanel Orientation="Horizontal"><TextBox Width="64" Text="{Binding LightingZoneWidthText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Physical lighting zone width" /><TextBox Width="64" Margin="7,0,0,0" Text="{Binding LightingZoneHeightText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Physical lighting zone height" /></StackPanel></StackPanel>
                  </local:AdaptiveUniformGrid>
                  <Button Content="Add physical zone" Command="{Binding AddLightingZoneCommand}" HorizontalAlignment="Left" Margin="0,2,0,10" automation:AutomationProperties.AutomationId="Lighting.AddZone" />
                  <ItemsControl ItemsSource="{Binding DraftLightingZones}">
                    <ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,5"><StackPanel><TextBlock Text="{Binding DeviceId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding LedIndices.Count, StringFormat={}{0} mapped LEDs}" Style="{StaticResource SubtleStyle}" Margin="0,3,0,0" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Separator />
                  <TextBlock Text="LAYOUT NAME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                  <TextBox Text="{Binding LightingLayoutName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Physical lighting layout name" automation:AutomationProperties.AutomationId="Lighting.LayoutName" />
                  <TextBlock Text="SAVED LAYOUT" Style="{StaticResource EyebrowStyle}" Margin="0,10,0,5" />
                  <ComboBox ItemsSource="{Binding LightingScenes}" SelectedItem="{Binding SelectedLightingScene}" automation:AutomationProperties.Name="Saved physical lighting layout" automation:AutomationProperties.AutomationId="Lighting.SelectedScene"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                  <WrapPanel Margin="0,12,0,0">
                    <Button Content="Save layout" Command="{Binding SaveLightingLayoutCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Lighting.SaveLayout" />
                    <Button Content="Apply Dynamic Lighting" Command="{Binding ApplyDynamicLightingSceneCommand}" Margin="0,0,8,8" ToolTip="{Binding DynamicLightingConflictReason}" ToolTipService.ShowOnDisabled="True" automation:AutomationProperties.AutomationId="Lighting.ApplyDynamicScene" />
                  </WrapPanel>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Lighting engine" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Stored scenes reference physical zones and validated effect graphs. Trusted JavaScript is hash-bound and rendered in a separate WebView2 host with network, navigation, file-request, permission, and service access blocked." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextTrimming="None" Margin="0,5,0,12" />
                  <WrapPanel>
                    <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="10,5" Margin="0,0,6,6"><TextBlock Text="Solid / gradient / wave" Style="{StaticResource BadgeTextStyle}" /></Border>
                    <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="10,5" Margin="0,0,6,6"><TextBlock Text="Temperature / notifications" Style="{StaticResource BadgeTextStyle}" /></Border>
                    <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="10,5" Margin="0,0,6,6"><TextBlock Text="Audio / screen ambience" Style="{StaticResource BadgeTextStyle}" /></Border>
                  </WrapPanel>
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
              <StackPanel>
                <Grid><StackPanel><TextBlock Text="Direct RGB qualification" Style="{StaticResource CardTitleStyle}" /><TextBlock Text="Aura and Lian Li remain read-only until an isolated Adapter Host trace, static-scene read-back, reset, and failure-containment checks pass for the exact controller." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel><Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4"><TextBlock Text="{Binding LightingQualificationPlans.Count, StringFormat={}{0} controller plans}" Style="{StaticResource BadgeTextStyle}" /></Border></Grid>
                <ItemsControl ItemsSource="{Binding LightingQualificationPlans}" Margin="0,10,0,0"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,8"><StackPanel><Grid><TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" /><StackPanel HorizontalAlignment="Right"><TextBlock Text="{Binding ReadinessLabel}" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Right" /><TextBlock Text="{Binding BlockingStepCount, StringFormat={}{0} blockers}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,0" /></StackPanel></Grid><TextBlock Text="{Binding Summary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,7" /><ItemsControl ItemsSource="{Binding Steps}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="160" /><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}" /><TextBlock Grid.Column="1" Text="{Binding State}" Foreground="{StaticResource WarningBrush}" /><TextBlock Grid.Column="2" Text="{Binding Evidence}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Guidance}" /></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                <TextBlock Text="No exact controller plan is available. Windows Dynamic Lighting and OpenRGB remain separate, explicitly selected paths." Style="{StaticResource SubtleStyle}" Margin="0,8,0,0" />
              </StackPanel>
            </Border>
              </StackPanel>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <!-- Automation -->
        <ScrollViewer x:Name="AutomationPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <Border Style="{StaticResource CardStyle}" Background="{StaticResource AccentSoftBrush}" BorderBrush="#31557F">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" FontSize="18" VerticalAlignment="Top" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="Manual selection always wins" FontWeight="SemiBold" FontSize="15" />
                  <TextBlock Text="Automation cannot override a profile you selected manually. Simple mode uses the safe default priority; Advanced Lab exposes detailed ordering and timing." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
              </Grid>
            </Border>
            <Grid x:Name="AdvancedAutomationPolicy" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="22">
              <StackPanel>
                <TextBlock Text="Rule evaluation" Style="{StaticResource CardTitleStyle}" />
                <TextBlock Text="Profile changes are deliberately damped to prevent rapid switching." Style="{StaticResource MutedStyle}" Margin="0,4,0,16" />
                <local:AdaptiveUniformGrid MaximumColumns="4" MinimumColumns="2" MinimumItemWidth="210">
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="01" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><TextBlock Text="Trigger" FontWeight="SemiBold" Margin="0,8,0,2" /><TextBlock Text="Process, foreground app, schedule, lock, idle, or hotkey" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="02" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><TextBlock Text="Entry debounce" FontWeight="SemiBold" Margin="0,8,0,2" /><TextBlock Text="Condition must hold for 5 seconds" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="03" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><TextBlock Text="Priority" FontWeight="SemiBold" Margin="0,8,0,2" /><TextBlock Text="Highest number, then latest activation" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="04" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><TextBlock Text="Cooldown" FontWeight="SemiBold" Margin="0,8,0,2" /><TextBlock Text="30 seconds between profile changes" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                </local:AdaptiveUniformGrid>
              </StackPanel>
              </Border>
            </Grid>
            <Border Style="{StaticResource CardStyle}" Padding="24">
              <StackPanel>
                <Grid>
                  <StackPanel>
                    <TextBlock Text="Automation rules" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="{Binding AutomationStatus}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <StackPanel HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ManualOverrideLabel}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                    <Button Content="Resume automation" Command="{Binding ResumeAutomationCommand}" Style="{StaticResource GhostButtonStyle}" Padding="8,3" MinHeight="0" Margin="0,5,0,0" />
                  </StackPanel>
                </Grid>
                <Separator />
                <local:AdaptiveUniformGrid MaximumColumns="3" MinimumColumns="1" MinimumItemWidth="220">
                  <StackPanel Margin="0,0,10,10"><TextBlock Text="RULE NAME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding NewRuleName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Automation rule name" automation:AutomationProperties.AutomationId="Automation.RuleName" /></StackPanel>
                  <StackPanel Margin="0,0,10,10"><TextBlock Text="TRIGGER" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding AutomationTriggerKinds}" SelectedItem="{Binding NewRuleTriggerKind}" automation:AutomationProperties.Name="Automation trigger type" automation:AutomationProperties.AutomationId="Automation.TriggerType" /></StackPanel>
                  <StackPanel Margin="0,0,10,10"><TextBlock Text="TRIGGER VALUE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding NewRuleTriggerValue, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Automation trigger value" automation:AutomationProperties.AutomationId="Automation.TriggerValue" /><TextBlock Text="{Binding NewRuleTriggerHint}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel>
                  <StackPanel Margin="0,0,10,10"><TextBlock Text="PROFILE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding NewRuleProfile}" automation:AutomationProperties.Name="Automation target profile" automation:AutomationProperties.AutomationId="Automation.TargetProfile"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                  <StackPanel Margin="0,0,10,10" Style="{StaticResource AdvancedOnlyPanelStyle}"><TextBlock Text="PRIORITY" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding NewRulePriorityText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Automation rule priority" automation:AutomationProperties.AutomationId="Automation.Priority" /></StackPanel>
                </local:AdaptiveUniformGrid>
                <TextBlock Text="Simple mode uses priority 100 for new rules. Open Advanced Lab to set an explicit priority and review the evaluation path." TextWrapping="Wrap" Margin="0,0,0,10">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers><DataTrigger Binding="{Binding IsAdvancedLab}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <Button Content="Add automation rule" Command="{Binding AddAutomationRuleCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding AutomationRules}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource InsetCardStyle}" Margin="0,5,0,0">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Trigger}" Style="{StaticResource MutedStyle}" Margin="0,3,0,0" />
                            <WrapPanel Margin="0,7,0,0"><TextBlock Text="Profile " Style="{StaticResource SubtleStyle}" /><TextBlock Text="{Binding Profile}" FontSize="12" /><TextBlock Text=" · Priority " Style="{StaticResource SubtleStyle}" /><TextBlock Text="{Binding Priority}" FontSize="12" /><TextBlock Text=" · " Style="{StaticResource SubtleStyle}" /><TextBlock Text="{Binding Status}" FontSize="12" Foreground="{StaticResource SafeBrush}" /></WrapPanel>
                          </StackPanel>
                          <Button Grid.Column="1" Content="Delete" Command="{Binding DataContext.DeleteAutomationRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource GhostButtonStyle}" Margin="12,0,0,0" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Margin="0,8,0,0">
                  <Border.Style><Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasAutomationRules}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
                  <StackPanel HorizontalAlignment="Center"><TextBlock Text="No saved rules" FontWeight="SemiBold" /><TextBlock Text="Add a typed rule above. Arbitrary commands and scripts are not supported." Style="{StaticResource MutedStyle}" Margin="0,4,0,0" /></StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <!-- Devices -->
        <ScrollViewer x:Name="EcosystemPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="User-session control plane" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Games, effects, macros, scripts, OSD, and capture run as the signed-in user. They never inherit service privileges." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextTrimming="None" Margin="0,4,0,0" />
                  <TextBlock Text="{Binding UserAgentStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" TextTrimming="None" Margin="0,8,0,0" />
                </StackPanel>
                <Border Grid.Column="1" BorderThickness="1" CornerRadius="12" Padding="10,5" VerticalAlignment="Top" Margin="16,0,0,0">
                  <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{StaticResource WarningSoftBrush}" /><Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsUserAgentOnline}" Value="True"><Setter Property="Background" Value="{StaticResource SafeSoftBrush}" /><Setter Property="BorderBrush" Value="{StaticResource SafeBrush}" /></DataTrigger></Style.Triggers></Style></Border.Style>
                  <TextBlock Text="{Binding UserAgentConnectionLabel}" FontSize="11" FontWeight="SemiBold" />
                </Border>
              </Grid>
            </Border>

            <local:AdaptiveUniformGrid MaximumColumns="4" MinimumColumns="2" MinimumItemWidth="210">
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="WORKFLOWS" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding WorkflowCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="Typed triggers and actions" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="LIGHTING" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding LightingSceneCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="{Binding EffectGraphCount, StringFormat={}{0} effect graphs}" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="INPUT" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding MacroCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="{Binding ScriptCount, StringFormat={}{0} trusted scripts}" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="OVERLAY &amp; CAPTURE" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding OsdLayoutCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="{Binding CapturePresetCount, StringFormat={}{0} capture presets}" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
            </local:AdaptiveUniformGrid>

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Local game library" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Reads installed Steam, Epic, GOG, Xbox, and Battle.net manifests. RigPilot does not download metadata." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextTrimming="None" Margin="0,4,0,0" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="Scan installed libraries" Command="{Binding ScanGamesCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="16,0,0,0" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Games}" Margin="0,12,0,0">
                  <ItemsControl.ItemsPanel><ItemsPanelTemplate><local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="340" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="38" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                          <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource AccentSoftBrush}" VerticalAlignment="Top"><TextBlock Text="&#xE7FC;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                          <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ExecutablePath}" Style="{StaticResource SubtleStyle}" ToolTip="{Binding ExecutablePath}" Margin="0,4,0,0" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Margin="0,12,0,0">
                  <Border.Style><Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasGames}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
                  <StackPanel HorizontalAlignment="Center"><TextBlock Text="No games indexed" FontWeight="SemiBold" /><TextBlock Text="Run a local scan to link profiles, scenes, macros, OSD layouts, and capture presets." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" /></StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <Grid>
                    <TextBlock Text="Visible macro recorder" Style="{StaticResource CardTitleStyle}" />
                    <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="8,3"><TextBlock Text="{Binding MacroRecordingSessionCount, StringFormat={}{0} sessions}" Style="{StaticResource BadgeTextStyle}" /></Border>
                  </Grid>
                  <TextBlock Text="Recording is user-session-only. Stop saves typed macro steps; Cancel discards captured input. Test sends input only after this explicit button press." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,12" />
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="118" /></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="MACRO NAME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding MacroRecordingName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="New macro recording name" automation:AutomationProperties.AutomationId="Games.MacroName" /></StackPanel>
                    <StackPanel Grid.Column="1"><TextBlock Text="MAXIMUM" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding MacroRecordingDurationOptions}" SelectedItem="{Binding MacroRecordingDurationSeconds}" automation:AutomationProperties.Name="Maximum macro recording duration" automation:AutomationProperties.AutomationId="Games.MacroDuration" /></StackPanel>
                  </Grid>
                  <TextBlock Text="{Binding MacroRecordingStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,9,0,10" automation:AutomationProperties.LiveSetting="Polite" />
                  <WrapPanel>
                    <Button Content="Record" Command="{Binding StartMacroRecordingCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Games.StartMacroRecording" />
                    <Button Content="Stop and save" Command="{Binding StopMacroRecordingCommand}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Games.StopMacroRecording" />
                    <Button Content="Cancel" Command="{Binding CancelMacroRecordingCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Games.CancelMacroRecording" />
                  </WrapPanel>
                  <Separator />
                  <TextBlock Text="SAVED MACRO" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                  <ComboBox ItemsSource="{Binding Macros}" SelectedItem="{Binding SelectedMacro}" automation:AutomationProperties.Name="Saved macro to test" automation:AutomationProperties.AutomationId="Games.SelectedMacro"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                  <Button Content="Test selected macro" Command="{Binding TestMacroCommand}" HorizontalAlignment="Left" Margin="0,10,0,0" ToolTip="Sends the selected macro to the active visible application." automation:AutomationProperties.AutomationId="Games.TestMacro" />
                  <Grid x:Name="AdvancedMacroEditor" Style="{StaticResource AdvancedOnlyPanelStyle}">
                    <StackPanel>
                  <Separator />
                  <TextBlock Text="Typed macro editor" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Edit only typed key presses. This editor cannot run commands or scripts; recorded pointer and media steps stay visible in the summary and can be replaced by a new recording." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,10" />
                  <TextBlock Text="MACRO NAME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                  <TextBox Text="{Binding MacroEditorName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Edited macro name" automation:AutomationProperties.AutomationId="Games.MacroEditorName" />
                  <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="118" /></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="VIRTUAL-KEY CODE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding MacroEditorKeyCodeText, UpdateSourceTrigger=PropertyChanged}" ToolTip="1-255. For example, 65 is A." automation:AutomationProperties.Name="Macro virtual-key code" automation:AutomationProperties.AutomationId="Games.MacroEditorKeyCode" /></StackPanel>
                    <StackPanel Grid.Column="1"><TextBlock Text="RELEASE MS" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding MacroEditorDelayMillisecondsText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Macro key release delay in milliseconds" automation:AutomationProperties.AutomationId="Games.MacroEditorDelay" /></StackPanel>
                  </Grid>
                  <TextBlock Text="{Binding MacroEditorSummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,9,0,9" automation:AutomationProperties.LiveSetting="Polite" />
                  <WrapPanel>
                    <Button Content="Add key press" Command="{Binding AddMacroKeyPressCommand}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Games.AddMacroKeyPress" />
                    <Button Content="Remove last typed key" Command="{Binding RemoveMacroKeyPressCommand}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Games.RemoveMacroKeyPress" />
                    <Button Content="Save macro edits" Command="{Binding SaveMacroEditCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.AutomationId="Games.SaveMacroEdit" />
                  </WrapPanel>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Per-game bundle" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Assignments are local. A game can select a hardware profile, lighting scene, macro, OSD layout, and capture preset without downloading game metadata." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,12" />
                  <TextBlock Text="GAME" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                  <ComboBox ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}" automation:AutomationProperties.Name="Game to configure" automation:AutomationProperties.AutomationId="Games.SelectedGame"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                  <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="175" Margin="0,11,0,0">
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="PROFILE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedGameProfile}" automation:AutomationProperties.Name="Profile for selected game" automation:AutomationProperties.AutomationId="Games.GameProfile"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="LIGHTING" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding LightingScenes}" SelectedItem="{Binding SelectedGameLightingScene}" automation:AutomationProperties.Name="Lighting layout for selected game" automation:AutomationProperties.AutomationId="Games.GameLighting"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="MACRO" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding Macros}" SelectedItem="{Binding SelectedGameMacro}" automation:AutomationProperties.Name="Macro for selected game" automation:AutomationProperties.AutomationId="Games.GameMacro"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="OSD" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding OsdLayouts}" SelectedItem="{Binding SelectedGameOsdLayout}" automation:AutomationProperties.Name="OSD layout for selected game" automation:AutomationProperties.AutomationId="Games.GameOsd"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="CAPTURE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding CapturePresets}" SelectedItem="{Binding SelectedGameCapturePreset}" automation:AutomationProperties.Name="Capture preset for selected game" automation:AutomationProperties.AutomationId="Games.GameCapture"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                  </local:AdaptiveUniformGrid>
                  <TextBlock Text="{Binding GameBundleSummary}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,10" />
                  <Button Content="Save game bundle" Command="{Binding SaveGameBundleCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" automation:AutomationProperties.AutomationId="Games.SaveBundle" />
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Local desktop OSD" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Shows selected live sensors in a transparent, non-activating window without injecting into any game. Optionally, the same sensor line can be published into a running RTSS on-screen display through RTSS's documented shared-memory contract, using only an OSD slot RigPilot owns." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,11" />
                  <TextBlock Text="LAYOUT" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                  <ComboBox ItemsSource="{Binding OsdLayouts}" SelectedItem="{Binding SelectedDesktopOsdLayout}" automation:AutomationProperties.Name="Desktop OSD layout" automation:AutomationProperties.AutomationId="Games.DesktopOsdLayout">
                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate>
                  </ComboBox>
                  <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="160" Margin="0,11,0,0">
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="MONITOR" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding OsdMonitors}" SelectedItem="{Binding SelectedOsdMonitor}" automation:AutomationProperties.Name="Desktop OSD monitor"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="ANCHOR" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding OsdScreenAnchors}" SelectedItem="{Binding SelectedOsdAnchor}" automation:AutomationProperties.Name="Desktop OSD screen anchor" /></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="HOTKEY" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding OsdHotkeyText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Use Ctrl, Alt, or Shift plus one letter, number, or function key." automation:AutomationProperties.Name="Desktop OSD hotkey" /></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="OPACITY / SCALE (%)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><StackPanel Orientation="Horizontal"><TextBox Width="72" Text="{Binding OsdOpacityText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Desktop OSD opacity" /><TextBox Width="72" Margin="8,0,0,0" Text="{Binding OsdScaleText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Desktop OSD scale" /></StackPanel></StackPanel>
                  </local:AdaptiveUniformGrid>
                  <Button Content="Save OSD settings" Command="{Binding SaveOsdPresentationCommand}" HorizontalAlignment="Left" Margin="0,0,0,1" automation:AutomationProperties.Name="Save desktop OSD settings" />
                  <TextBlock Text="{Binding DesktopOsdStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,9,0,10" automation:AutomationProperties.LiveSetting="Polite" />
                  <WrapPanel>
                    <Button Content="Show OSD" Command="{Binding ShowDesktopOsdCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" automation:AutomationProperties.Name="Show local desktop OSD" automation:AutomationProperties.AutomationId="Games.ShowDesktopOsd" />
                    <Button Content="Hide OSD" Command="{Binding HideDesktopOsdCommand}" Style="{StaticResource GhostButtonStyle}" automation:AutomationProperties.Name="Hide local desktop OSD" automation:AutomationProperties.AutomationId="Games.HideDesktopOsd" />
                  </WrapPanel>
                  <TextBlock Text="RTSS IN-GAME OSD" Style="{StaticResource EyebrowStyle}" Margin="0,14,0,5" />
                  <TextBlock Text="{Binding RtssOsdPublishStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,10" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Games.RtssOsdPublishStatus" />
                  <WrapPanel>
                    <Button Content="Publish sensor line" Command="{Binding PublishRtssOsdCommand}" Margin="0,0,8,0" automation:AutomationProperties.Name="Publish RigPilot sensor line to RTSS OSD" automation:AutomationProperties.AutomationId="Games.PublishRtssOsd" />
                    <Button Content="Stop publishing" Command="{Binding ReleaseRtssOsdCommand}" Style="{StaticResource GhostButtonStyle}" automation:AutomationProperties.Name="Stop publishing to RTSS OSD" automation:AutomationProperties.AutomationId="Games.ReleaseRtssOsd" />
                    <Button Content="Read frame stats" Command="{Binding ReadRtssFrameStatsCommand}" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" automation:AutomationProperties.Name="Read RTSS frame statistics" automation:AutomationProperties.AutomationId="Games.ReadRtssFrameStats" />
                  </WrapPanel>
                  <TextBlock Text="{Binding RtssFrameStatsStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,9,0,0" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Games.RtssFrameStatsStatus" />
                  <TextBlock Text="FRAME-RATE BENCHMARK" Style="{StaticResource EyebrowStyle}" Margin="0,14,0,5" />
                  <TextBlock Text="{Binding FrametimeBenchmarkStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,10" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Games.FrametimeBenchmarkStatus" />
                  <WrapPanel>
                    <Button Content="Start benchmark" Command="{Binding StartFrametimeBenchmarkCommand}" Margin="0,0,8,0" automation:AutomationProperties.Name="Start frame-rate benchmark" automation:AutomationProperties.AutomationId="Games.StartFrametimeBenchmark" />
                    <Button Content="Stop benchmark" Command="{Binding StopFrametimeBenchmarkCommand}" Style="{StaticResource GhostButtonStyle}" automation:AutomationProperties.Name="Stop frame-rate benchmark" automation:AutomationProperties.AutomationId="Games.StopFrametimeBenchmark" />
                  </WrapPanel>
                  <TextBlock Text="PER-FRAME BENCHMARK (INTEL PRESENTMON)" Style="{StaticResource EyebrowStyle}" Margin="0,14,0,5" />
                  <TextBlock Text="{Binding PresentMonBenchmarkStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,10" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Games.PresentMonBenchmarkStatus" />
                  <WrapPanel>
                    <Button Content="Start per-frame benchmark" Command="{Binding StartPresentMonBenchmarkCommand}" Margin="0,0,8,0" automation:AutomationProperties.Name="Start per-frame benchmark via Intel PresentMon" automation:AutomationProperties.AutomationId="Games.StartPresentMonBenchmark" />
                    <Button Content="Stop per-frame benchmark" Command="{Binding StopPresentMonBenchmarkCommand}" Style="{StaticResource GhostButtonStyle}" automation:AutomationProperties.Name="Stop per-frame benchmark" automation:AutomationProperties.AutomationId="Games.StopPresentMonBenchmark" />
                  </WrapPanel>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Explicit PNG snapshot" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Captures one selected display or visible window only after this button press. PNG files remain under Pictures\RigPilot\Snapshots and are never sent to the service or a report." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,5,0,11" />
                  <TextBlock Text="TARGET" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                  <ComboBox ItemsSource="{Binding CaptureTargets}" SelectedItem="{Binding SelectedCaptureTarget}" automation:AutomationProperties.Name="Desktop snapshot target" automation:AutomationProperties.AutomationId="Games.SnapshotTarget">
                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate></ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="{Binding DesktopSnapshotStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,9,0,10" automation:AutomationProperties.LiveSetting="Polite" />
                  <Button Content="Save PNG snapshot" Command="{Binding CaptureDesktopSnapshotCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" automation:AutomationProperties.Name="Save explicit desktop PNG snapshot" automation:AutomationProperties.AutomationId="Games.CaptureSnapshot" />
                  <Separator />
                  <TextBlock Text="Windows Graphics Capture video" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="{Binding WgcRecordingStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,9" />
                  <TextBlock Text="{Binding VideoRecordingStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,0,0,10" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Games.VideoRecordingStatus" />
                  <WrapPanel>
                    <Button Content="Start recording" Command="{Binding StartVideoRecordingCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" automation:AutomationProperties.Name="Start bounded video recording of the selected target" automation:AutomationProperties.AutomationId="Games.StartVideoRecording" />
                    <Button Content="Stop recording" Command="{Binding StopVideoRecordingCommand}" automation:AutomationProperties.Name="Stop the current video recording" automation:AutomationProperties.AutomationId="Games.StopVideoRecording" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <Border>
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers><DataTrigger Binding="{Binding IsAdvancedLab}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="Advanced Lab execution boundaries" Style="{StaticResource CardTitleStyle}" />
                <TextBlock Text="Script and effect trust is SHA-256 bound and invalidated after edits. Automation and effects run as the signed-in user in separate bounded processes. External overlay and capture states are discovered without injection or privileged service access." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextTrimming="None" Margin="0,5,0,12" />
                <local:AdaptiveUniformGrid MaximumColumns="4" MinimumColumns="1" MinimumItemWidth="220">
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="AUTOMATION HOST" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="Signed-in user only" FontWeight="SemiBold" Margin="0,6,0,0" /><TextBlock Text="Timeout, bounded output, child-tree termination" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel></Border>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="EFFECT HOST" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="Sandbox tested" FontWeight="SemiBold" Margin="0,6,0,0" /><TextBlock Text="Hash trust, request denial, 512 MB cap, watchdog" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel></Border>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="RTSS" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding RtssBridgeStatus}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0" /><TextBlock Text="No process injection or unreviewed shared-memory writes" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel></Border>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="GAME BAR" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding GameBarBridgeStatus}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0" /><TextBlock Text="Widget IPC is restricted to the user agent." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel></Border>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,10,10"><StackPanel><TextBlock Text="CAPTURE" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding CaptureBridgeStatus}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0" /><TextBlock Text="Coordinator models stop, abort, target loss, and encoder failure." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel></Border>
                </local:AdaptiveUniformGrid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <!-- Devices -->
        <ScrollViewer x:Name="DevicesPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <Border Style="{StaticResource CardStyle}" Padding="16">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Grid MaxWidth="540" HorizontalAlignment="Stretch">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Panel.ZIndex="2" />
                  <TextBox x:Name="DeviceSearchBox" Grid.ColumnSpan="3" Text="{Binding DeviceSearchText, UpdateSourceTrigger=PropertyChanged}" Padding="38,8,42,8" automation:AutomationProperties.Name="Search devices" automation:AutomationProperties.AutomationId="Devices.Search" />
                  <TextBlock Grid.Column="1" Text="Search by device, type, manufacturer, or model" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding DeviceSearchText}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <Button Grid.Column="2" Command="{Binding ClearDeviceSearchCommand}" Style="{StaticResource GhostButtonStyle}" Padding="10,4" MinHeight="0" ToolTip="Clear search" automation:AutomationProperties.Name="Clear device search"><TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" /></Button>
                </Grid>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <TextBlock Text="{Binding DeviceResultSummary}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                  <TextBlock Text="Exact identifiers only" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,0" />
                  <TextBlock Text="{Binding DeviceCompatibilitySummary}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" MaxWidth="360" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" ToolTip="Read-only family recognition from observed Windows identity. It does not qualify hardware writes." automation:AutomationProperties.Name="Detected compatibility families" automation:AutomationProperties.AutomationId="Devices.CompatibilitySummary" />
                </StackPanel>
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Padding="17" Margin="0,12,0,0">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Connected peripherals" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="A read-only HID inventory scanned inside the crash-isolated Adapter Host. Keyboards, mice, headset controls, RGB and AIO controllers are classified by HID usage; no device is opened for output and no write capability is created." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="Scan peripherals" Command="{Binding ScanHidInventoryCommand}" Margin="12,0,0,0" VerticalAlignment="Top" automation:AutomationProperties.Name="Scan connected peripherals" automation:AutomationProperties.AutomationId="Devices.ScanHid" />
                </Grid>
                <TextBlock Text="{Binding HidInventoryStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,12,0,2" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Devices.HidInventoryStatus" />
                <Grid Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="LIQUID COOLER TELEMETRY" Style="{StaticResource EyebrowStyle}" />
                    <TextBlock Text="{Binding KrakenTelemetryStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Devices.KrakenTelemetryStatus" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="Read cooler status" Command="{Binding ReadKrakenTelemetryCommand}" Margin="12,0,0,0" VerticalAlignment="Top" automation:AutomationProperties.Name="Read Kraken liquid cooler telemetry" automation:AutomationProperties.AutomationId="Devices.ReadKrakenTelemetry" />
                </Grid>
                <ItemsControl ItemsSource="{Binding HidDevices}" Margin="0,6,0,0" automation:AutomationProperties.Name="Connected peripherals list" automation:AutomationProperties.AutomationId="Devices.HidInventory">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,9">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <Border Width="25" Height="25" CornerRadius="6" Background="{StaticResource SurfaceRaisedBrush}" VerticalAlignment="Top">
                            <TextBlock Text="&#xE772;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                          <StackPanel Grid.Column="1" Margin="7,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Classes}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,0" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding Identity}" Style="{StaticResource MutedStyle}" VerticalAlignment="Center" FontFamily="Consolas" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Padding="17" Margin="0,12,0,0">
                <StackPanel>
                  <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Monitor brightness" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Detect every display in this signed-in Windows session. External monitors use DDC/CI; Windows-managed panels use WMI. Unsupported displays remain listed with their exact capability reason." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="Refresh monitors" Command="{Binding RefreshMonitorBrightnessCommand}" Margin="12,0,0,0" VerticalAlignment="Top" automation:AutomationProperties.Name="Refresh detected monitors" automation:AutomationProperties.AutomationId="Devices.RefreshMonitorBrightness" />
                </Grid>
                <TextBlock Text="{Binding MonitorBrightnessStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,12,0,12" automation:AutomationProperties.LiveSetting="Polite" automation:AutomationProperties.AutomationId="Devices.MonitorBrightnessStatus" />
                <Grid IsEnabled="{Binding IsUserAgentOnline}">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="110" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="DISPLAY" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <ComboBox ItemsSource="{Binding MonitorBrightnessDevices}" SelectedItem="{Binding SelectedMonitorBrightnessDevice}" automation:AutomationProperties.Name="Monitor brightness display" automation:AutomationProperties.AutomationId="Devices.MonitorBrightnessDevice">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource SubtleStyle}" Text="{Binding TransportLabel}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource SubtleStyle}" Text="{Binding Reason}" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="BRIGHTNESS (%)" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <TextBox Text="{Binding MonitorBrightnessPercentText, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSelectedMonitorBrightnessWritable}" HorizontalContentAlignment="Center" automation:AutomationProperties.Name="Monitor brightness percent" automation:AutomationProperties.AutomationId="Devices.MonitorBrightnessPercent" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="Apply brightness" Command="{Binding SetMonitorBrightnessCommand}" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Bottom" automation:AutomationProperties.Name="Apply selected monitor brightness" automation:AutomationProperties.AutomationId="Devices.ApplyMonitorBrightness" />
                </Grid>
                <CheckBox IsChecked="{Binding MonitorBrightnessDeviceConfirmed}" IsEnabled="{Binding IsSelectedMonitorBrightnessWritable}" Margin="0,12,0,0" automation:AutomationProperties.Name="Confirm selected monitor brightness" automation:AutomationProperties.AutomationId="Devices.ConfirmMonitorBrightness">
                  <TextBlock Text="I confirm this exact selected display may change brightness now. RigPilot will accept the change only after immediate read-back." TextWrapping="Wrap" />
                </CheckBox>
                <ItemsControl ItemsSource="{Binding MonitorBrightnessDevices}" Margin="0,12,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,8">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding TransportLabel}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding RangeLabel}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding Reason}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,2,0,0" />
                          </StackPanel>
                          <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding State}" Style="{StaticResource BadgeTextStyle}" HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding CurrentPercent, StringFormat={}{0}%}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,3,0,0" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Grid x:Name="AdvancedDeviceOwnership" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="17" Margin="0,12,0,0">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Control ownership" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Preview exact competing binaries, store identity-bound consent, then take over only after firmware/default reset verification." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <Border Grid.Column="1" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4" VerticalAlignment="Top">
                    <TextBlock Text="{Binding TakeoverExecutorStatus.CanExecute, StringFormat=EXECUTOR: {0}}" Style="{StaticResource BadgeTextStyle}" />
                  </Border>
                </Grid>
                <TextBlock Text="{Binding OwnershipStatus}" TextWrapping="Wrap" Style="{StaticResource SubtleStyle}" Margin="0,12,0,0" automation:AutomationProperties.LiveSetting="Polite" />
                <TextBlock Text="{Binding TakeoverPlanSummary}" TextWrapping="Wrap" Style="{StaticResource SubtleStyle}" Margin="0,4,0,12" />
                <WrapPanel>
                  <Button Content="Preview competitors" Command="{Binding PreviewTakeoverCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" ToolTip="Reads exact path, product, publisher, signer, and SHA-256 identity. It does not stop a process or change startup." automation:AutomationProperties.Name="Preview exact competing controls" automation:AutomationProperties.AutomationId="Devices.PreviewTakeover" />
                  <Button Content="Give control back" Command="{Binding ReleaseOwnershipCommand}" Margin="0,0,8,8" ToolTip="Restores firmware/default control and backed-up startup entries for the active ownership transaction." automation:AutomationProperties.Name="Give control back" automation:AutomationProperties.AutomationId="Devices.ReleaseOwnership" />
                </WrapPanel>
                <Grid Margin="0,5,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                  <StackPanel Margin="0,0,7,0">
                    <TextBlock Text="EXACT PROCESS TARGET" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <ComboBox ItemsSource="{Binding TakeoverTargets}" SelectedItem="{Binding SelectedTakeoverTarget}" automation:AutomationProperties.Name="Exact takeover target" automation:AutomationProperties.AutomationId="Devices.TakeoverTarget">
                      <ComboBox.ItemTemplate><DataTemplate><StackPanel><TextBlock Text="{Binding DisplayName}" /><TextBlock Text="{Binding ExecutablePath}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" /></StackPanel></DataTemplate></ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="7,0,0,0">
                    <TextBlock Text="IDENTITY" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" />
                    <TextBlock Text="{Binding SelectedTakeoverTarget.Publisher}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding SelectedTakeoverTarget.Sha256}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                  </StackPanel>
                </Grid>
                <WrapPanel Margin="0,12,0,0">
                  <CheckBox IsChecked="{Binding TakeoverAllowForceTermination}" Content="Allow force-stop after 5 s" Margin="0,0,14,8" automation:AutomationProperties.AutomationId="Devices.TakeoverForceStop" />
                  <CheckBox IsChecked="{Binding TakeoverDisableStartup}" Content="Disable matching Run/RunOnce startup" Margin="0,0,14,8" automation:AutomationProperties.AutomationId="Devices.TakeoverStartup" />
                  <Button Content="Store exact consent" Command="{Binding GrantTakeoverConsentCommand}" Margin="0,0,8,8" ToolTip="Consent is invalidated if the executable path, product, publisher, signer, or SHA-256 changes." automation:AutomationProperties.Name="Store exact takeover consent" automation:AutomationProperties.AutomationId="Devices.GrantTakeoverConsent" />
                </WrapPanel>
                <CheckBox IsChecked="{Binding TakeoverExactProcessesConfirmed}" Margin="0,3,0,8" automation:AutomationProperties.Name="Confirm exact takeover targets" automation:AutomationProperties.AutomationId="Devices.ConfirmTakeover">
                  <TextBlock Text="I confirm that only the exact previewed and consented binaries may be stopped after reset verification succeeds." TextWrapping="Wrap" />
                </CheckBox>
                <Button Content="Take over qualified controls" Command="{Binding ExecuteTakeoverCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" ToolTip="Unavailable in unsigned or unqualified builds. No control is acquired unless every target identity, stored consent, default reset, and ownership lease check succeeds." automation:AutomationProperties.Name="Take over qualified controls" automation:AutomationProperties.AutomationId="Devices.ExecuteTakeover" />
              </StackPanel>
              </Border>
            </Grid>

            <Grid x:Name="AdvancedDeviceDecisionMatrix" Style="{StaticResource AdvancedOnlyPanelStyle}">
              <Border Style="{StaticResource CardStyle}" Padding="17" Margin="0,12,0,0">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="Control decision matrix" Style="{StaticResource CardTitleStyle}" />
                    <TextBlock Text="Exact capability state, ownership, evidence, and the next safe action. A visible control is not a permission to write." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                  <Border Grid.Column="1" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="9,4" VerticalAlignment="Top">
                    <TextBlock Text="{Binding CapabilityDecisions.Count, StringFormat={}{0} decisions}" Style="{StaticResource BadgeTextStyle}" />
                  </Border>
                </Grid>
                <TextBlock Text="{Binding CapabilityDecisionSummary}" Style="{StaticResource SubtleStyle}" Margin="0,10,0,8" />
                <ItemsControl ItemsSource="{Binding CapabilityDecisions}" ItemTemplate="{StaticResource CapabilityTemplate}" />
                <TextBlock Text="No capability decisions are available until inventory completes." Margin="0,8,0,0">
                  <TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasCapabilityDecisions}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
              </StackPanel>
              </Border>
            </Grid>

            <ItemsControl ItemsSource="{Binding Devices}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="340" /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource CardStyle}" Padding="17">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="44" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource SurfaceRaisedBrush}" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Glyph}" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Details}" Style="{StaticResource MutedStyle}" TextWrapping="Wrap" TextTrimming="None" Margin="0,4,0,0" />
                      </StackPanel>
                      <Border Grid.Column="2" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="8,3" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Kind}" Style="{StaticResource BadgeTextStyle}" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border>
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers><DataTrigger Binding="{Binding HasDevices}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="22" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="No devices match this search" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0" />
                <TextBlock Text="Clear the search to return to the complete inventory." Style="{StaticResource MutedStyle}" HorizontalAlignment="Center" Margin="0,3,0,0" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <!-- Diagnostics -->
        <ScrollViewer x:Name="DiagnosticsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,0,10,18">
            <local:AdaptiveUniformGrid MaximumColumns="4" MinimumColumns="2" MinimumItemWidth="230">
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="WARNINGS" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding WarningCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="Require review" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="CONFLICTS" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding RunningConflictCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="Competing writers" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="SERVICE" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding ServiceVersion}" ToolTip="{Binding ServiceVersion}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,10,0,3" /><TextBlock Text="{Binding ServiceUptimeText, StringFormat=Uptime {0}}" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="REVISION" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding StateRevisionText}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="Transactional state" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="DRIVER UPDATES" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding PendingUpdateCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="Pending or recovery-required" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="ADAPTER TRACE" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding AdapterTraceCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="Bounded local operations" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="HEALTH ALERTS" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding ActiveHealthAlertCount}" Style="{StaticResource MetricValueStyle}" Margin="0,7,0,2" /><TextBlock Text="Rules requiring review" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
              <Border Style="{StaticResource CardStyle}" Padding="17"><StackPanel><TextBlock Text="RECOVERY" Style="{StaticResource EyebrowStyle}" /><TextBlock Text="{Binding SafeModeLabel}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,3" /><TextBlock Text="Safe mode and rollback state" Style="{StaticResource SubtleStyle}" /></StackPanel></Border>
            </local:AdaptiveUniformGrid>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Warnings and conflicts" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="RigPilot reports overlap but never terminates another program." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,2" />
                  <ItemsControl ItemsSource="{Binding Diagnostics}" ItemTemplate="{StaticResource DiagnosticTemplate}" />
                  <Border Margin="0,13,0,0">
                    <Border.Style>
                      <Style TargetType="Border" BasedOn="{StaticResource EmptyStateStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers><DataTrigger Binding="{Binding HasDiagnostics}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                      </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="21" Foreground="{StaticResource SafeBrush}" HorizontalAlignment="Center" />
                      <TextBlock Text="No active warnings" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0" />
                      <TextBlock Text="No competing controller was detected." Style="{StaticResource MutedStyle}" HorizontalAlignment="Center" Margin="0,3,0,0" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Adapter health" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Latest health result from each built-in adapter" Style="{StaticResource MutedStyle}" Margin="0,4,0,5" />
                  <ItemsControl ItemsSource="{Binding AdapterHealth}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                          <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,10,0">
                              <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource CriticalBrush}" /><Style.Triggers><DataTrigger Binding="{Binding Healthy}" Value="True"><Setter Property="Fill" Value="{StaticResource SafeBrush}" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                            </Ellipse>
                            <StackPanel Grid.Column="1">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding Message}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                              <TextBlock Text="{Binding Status}" FontSize="12" HorizontalAlignment="Right" />
                              <TextBlock Text="{Binding Checked}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,0" />
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Driver update safety" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="{Binding UpdatePlatformStatus}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,7,0,0" />
                  <TextBlock Text="Only a staged INF package for an exact detected device can proceed. Firmware and BIOS packages remain vendor-workflow only." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Adapter activity trace" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="The current service session retains a bounded, redacted record of adapter operations. Values, paths, and raw exception messages are excluded." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,5" />
                  <ItemsControl ItemsSource="{Binding AdapterTrace}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                          <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                              <WrapPanel><TextBlock Text="{Binding Adapter}" FontWeight="SemiBold" /><TextBlock Text="  " /><TextBlock Text="{Binding Operation}" /><TextBlock Text="  " /><TextBlock Text="{Binding Target}" Style="{StaticResource SubtleStyle}" /></WrapPanel>
                              <TextBlock Text="{Binding Message}" Style="{StaticResource SubtleStyle}" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="{Binding Status}" HorizontalAlignment="Right" /><TextBlock Text="{Binding Timestamp}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,0" /></StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="No trace is available from this service version yet." Margin="0,8,0,0">
                    <TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasAdapterTrace}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                  </TextBlock>
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <Grid><StackPanel><TextBlock Text="Sensor alerts and health rules" Style="{StaticResource CardTitleStyle}" /><TextBlock Text="Rules are typed and local. Emergency-profile actions request operator confirmation; only safe mode can be entered automatically." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel><Border HorizontalAlignment="Right" Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="12" Padding="8,3"><TextBlock Text="{Binding ActiveHealthAlertCount, StringFormat={}{0} active}" Style="{StaticResource BadgeTextStyle}" /></Border></Grid>
                  <Border Style="{StaticResource InsetCardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                      <TextBlock Text="Recommended notify-only baseline" FontWeight="SemiBold" />
                      <TextBlock Text="Temperature, pump RPM, stale telemetry, WHEA, and display-driver reset rules are installed only after this explicit action. They do not change hardware." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                      <TextBlock Text="{Binding HealthRecommendationStatus}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,4,0,8" />
                      <Button Content="Add recommended rules" Command="{Binding AddRecommendedHealthRulesCommand}" HorizontalAlignment="Left" automation:AutomationProperties.Name="Add recommended health rules" automation:AutomationProperties.AutomationId="Diagnostics.AddRecommendedHealthRules" />
                    </StackPanel>
                  </Border>
                  <TextBlock Text="RULE NAME" Style="{StaticResource EyebrowStyle}" Margin="0,12,0,5" /><TextBox Text="{Binding NewHealthRuleName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Health rule name" />
                  <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="170" Margin="0,10,0,0">
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="CONDITION" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding HealthRuleConditions}" SelectedItem="{Binding NewHealthRuleCondition}" automation:AutomationProperties.Name="Health rule condition" /></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="SENSOR" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding MonitoringTrends}" SelectedItem="{Binding SelectedHealthTrend}" automation:AutomationProperties.Name="Health rule sensor"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="THRESHOLD" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding NewHealthThresholdText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Health rule threshold" /></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="ACTION" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding HealthRuleActions}" SelectedItem="{Binding NewHealthRuleAction}" automation:AutomationProperties.Name="Health rule action" /></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="OBSERVATIONS / COOLDOWN S" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><StackPanel Orientation="Horizontal"><TextBox Width="70" Text="{Binding NewHealthConsecutiveText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Health rule consecutive observations" /><TextBox Width="70" Margin="8,0,0,0" Text="{Binding NewHealthCooldownText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Health rule cooldown" /></StackPanel></StackPanel>
                    <StackPanel Margin="0,0,8,9"><TextBlock Text="EMERGENCY PROFILE" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedEmergencyProfile}" automation:AutomationProperties.Name="Health rule emergency profile"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox></StackPanel>
                  </local:AdaptiveUniformGrid>
                  <Button Content="Save health rule" Command="{Binding SaveHealthRuleCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" automation:AutomationProperties.Name="Save health rule" />
                  <ItemsControl ItemsSource="{Binding HealthRules}" Margin="0,12,0,0"><ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold" /><TextBlock Text="{Binding Summary}" Style="{StaticResource SubtleStyle}" Margin="0,2,0,0" /><TextBlock Text="{Binding Source}" Style="{StaticResource SubtleStyle}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" /></StackPanel><Button Grid.Column="1" Content="Delete" Command="{Binding DataContext.DeleteHealthRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource GhostButtonStyle}" VerticalAlignment="Center" /></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <Grid><StackPanel><TextBlock Text="Recovery and active alerts" Style="{StaticResource CardTitleStyle}" /><TextBlock Text="After a crash or fault, inspect pending recovery before enabling any automation or write workflow." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel><Border HorizontalAlignment="Right" Background="{StaticResource WarningSoftBrush}" CornerRadius="12" Padding="8,3"><TextBlock Text="{Binding SafeModeLabel}" Style="{StaticResource BadgeTextStyle}" /></Border></Grid>
                  <TextBlock Text="{Binding SafetyRecoveryGuidance}" TextWrapping="Wrap" Margin="0,11,0,8" />
                  <TextBlock Text="SAFE-MODE REASON" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><TextBox Text="{Binding SafeModeReason, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Safe mode reason" />
                  <WrapPanel Margin="0,9,0,8"><Button Content="Enter safe mode" Command="{Binding EnableSafeModeCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.Name="Enter safe mode" /><Button Content="Exit safe mode" Command="{Binding DisableSafeModeCommand}" Margin="0,0,8,8" automation:AutomationProperties.Name="Exit safe mode" /></WrapPanel>
                  <ItemsControl ItemsSource="{Binding HealthAlerts}"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding RuleName}" FontWeight="SemiBold" /><TextBlock Text="{Binding Message}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,3,0,0" /><TextBlock Text="{Binding Action}" Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,3,0,0" /></StackPanel><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="{Binding State}" HorizontalAlignment="Right" FontWeight="SemiBold" /><TextBlock Text="{Binding Timestamp}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" Margin="0,2,0,5" /><Button Content="Acknowledge" Command="{Binding DataContext.AcknowledgeHealthAlertCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource GhostButtonStyle}" /></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                  <TextBlock Text="No health alerts are active." Margin="0,8,0,0"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource SubtleStyle}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasHealthAlerts}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Sensor aliases and pins" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Alias and pinning affect only your dashboard. They cannot change sensor collection or hardware controls." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,12" />
                  <TextBlock Text="LIVE SENSOR" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,5" /><ComboBox ItemsSource="{Binding MonitoringTrends}" SelectedItem="{Binding SelectedMonitoringTrend}" automation:AutomationProperties.Name="Monitoring sensor"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                  <TextBlock Text="ALIAS (OPTIONAL)" Style="{StaticResource EyebrowStyle}" Margin="0,10,0,5" /><TextBox Text="{Binding SensorAliasText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Monitoring sensor alias" />
                  <CheckBox IsChecked="{Binding SelectedSensorPinned}" Content="Pin this sensor at the top of the workspace" Margin="0,9,0,10" />
                  <Button Content="Save monitoring preference" Command="{Binding SaveMonitoringPreferencesCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" automation:AutomationProperties.Name="Save monitoring preference" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Hardware evidence workflow" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Creates a bounded local JSON record of exact device identity, driver/firmware evidence, read-only telemetry state, traces, recovery status, and qualification outcomes. It is not uploaded." Style="{StaticResource MutedStyle}" TextWrapping="Wrap" Margin="0,4,0,12" />
                  <WrapPanel><Button Content="Export local evidence" Click="SaveEvidence_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" automation:AutomationProperties.Name="Export local hardware evidence" /><Button Content="Export monitoring CSV" Click="SaveMonitoringExport_Click" Margin="0,0,8,8" automation:AutomationProperties.Name="Export monitoring CSV" /></WrapPanel>
                  <TextBlock Text="Evidence never grants write capability by itself. A signed build and physical qualification remain separate gates." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>

            <local:AdaptiveUniformGrid MaximumColumns="2" MinimumColumns="1" MinimumItemWidth="390">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Diagnostic tools" Style="{StaticResource CardTitleStyle}" />
                  <TextBlock Text="Local actions only. Nothing is uploaded from this page." Style="{StaticResource MutedStyle}" Margin="0,4,0,14" />
                  <WrapPanel>
                    <Button Content="Save report preview" Click="SaveReport_Click" Margin="0,0,8,8" automation:AutomationProperties.Name="Save redacted report preview" />
                    <Button Content="Copy summary" Click="CopySummary_Click" Margin="0,0,8,8" />
                    <Button Content="Open data folder" Click="OpenDataFolder_Click" Margin="0,0,8,8" />
                    <Button Content="Reset verified controls" Command="{Binding ResetVerifiedCommand}" Margin="0,0,8,8" ToolTipService.ShowOnDisabled="True" ToolTip="Available only when resettable Verified controls exist." />
                  </WrapPanel>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Privacy and app behaviour" Style="{StaticResource CardTitleStyle}" />
                  <Grid Margin="0,12,0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Close button" /><TextBlock Grid.Column="1" Text="Hide to tray" Style="{StaticResource MutedStyle}" /></Grid>
                  <Grid Margin="0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Global shortcut" /><TextBlock Grid.Column="1" Text="Ctrl+Shift+F12" Style="{StaticResource MutedStyle}" /></Grid>
                  <Grid Margin="0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Report upload" /><TextBlock Grid.Column="1" Text="Disabled" Foreground="{StaticResource SafeBrush}" /></Grid>
                  <TextBlock Text="Report previews remove identity, exact paths, serial numbers, and network inventory before saving." Style="{StaticResource SubtleStyle}" TextWrapping="Wrap" Margin="0,12,0,0" />
                </StackPanel>
              </Border>
            </local:AdaptiveUniformGrid>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- Persistent footer context -->
      <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="28,9" Background="{StaticResource SidebarBrush}">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0">
              <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource WarningBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsServiceOnline}" Value="True"><Setter Property="Fill" Value="{StaticResource SafeBrush}" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding ServiceStateLabel}" FontSize="12" />
          </StackPanel>
          <Border Grid.Column="1" Background="{StaticResource BorderBrush}" Width="1" Margin="14,0" />
          <StackPanel Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="Profile" Style="{StaticResource SubtleStyle}" Margin="0,0,6,0" />
            <TextBlock Text="{Binding ActiveProfileName}" FontSize="12" FontWeight="SemiBold" />
          </StackPanel>
          <TextBlock Grid.Column="3" Text="{Binding WriteStateLabel}" Style="{StaticResource SubtleStyle}" HorizontalAlignment="Right" />
        </Grid>
      </Border>

      <!-- Busy overlay prevents duplicate mutations and makes long hardware work explicit. -->
      <Border Grid.RowSpan="4" Background="#D90C1017" Panel.ZIndex="100" automation:AutomationProperties.LiveSetting="Assertive" automation:AutomationProperties.Name="RigPilot is working">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers><DataTrigger Binding="{Binding IsBusy}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
          </Style>
        </Border.Style>
        <Border Style="{StaticResource CardStyle}" Width="330" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
          <StackPanel>
            <TextBlock Text="RigPilot" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding BusyMessage}" Style="{StaticResource MutedStyle}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,7,0,15" />
            <ProgressBar IsIndeterminate="True" Height="4" Foreground="{StaticResource AccentBrush}" Background="{StaticResource BorderBrush}" />
          </StackPanel>
        </Border>
      </Border>
    </Grid>
  </Grid>
</Window>
