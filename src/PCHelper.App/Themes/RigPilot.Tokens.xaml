<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ================================================================
       RigPilot design tokens.
       Codifies the app's existing visual language (graphite surfaces,
       iOS-system status hues, pill buttons, radius-11 glass cards) as
       named tokens so new XAML stops hard-coding values. Components
       reference these with DynamicResource so a future light theme can
       swap this dictionary at runtime.
       ================================================================ -->

  <!-- Capability-state colours, one per CapabilityAccessState the user
       can see. Verified/Experimental reuse the established Safe/Warning
       hues so the same state never has two colours in one window.
       Blocked is deliberately NOT a warning colour: a competing writer
       is a normal, recoverable situation (informational), and amber is
       reserved for states that carry real risk (Experimental). -->
  <Color x:Key="StateVerifiedColor">#30D158</Color>
  <Color x:Key="StateVerifiedSoftColor">#2930D158</Color>
  <Color x:Key="StateExperimentalColor">#FFB340</Color>
  <Color x:Key="StateExperimentalSoftColor">#29FF9F0A</Color>
  <Color x:Key="StateBlockedColor">#8FA8C8</Color>
  <Color x:Key="StateBlockedSoftColor">#1F8FB4FF</Color>
  <Color x:Key="StateUnavailableColor">#7A7F8A</Color>
  <Color x:Key="StateUnavailableSoftColor">#14FFFFFF</Color>

  <SolidColorBrush x:Key="StateVerifiedBrush" Color="{StaticResource StateVerifiedColor}" />
  <SolidColorBrush x:Key="StateVerifiedSoftBrush" Color="{StaticResource StateVerifiedSoftColor}" />
  <SolidColorBrush x:Key="StateExperimentalBrush" Color="{StaticResource StateExperimentalColor}" />
  <SolidColorBrush x:Key="StateExperimentalSoftBrush" Color="{StaticResource StateExperimentalSoftColor}" />
  <SolidColorBrush x:Key="StateBlockedBrush" Color="{StaticResource StateBlockedColor}" />
  <SolidColorBrush x:Key="StateBlockedSoftBrush" Color="{StaticResource StateBlockedSoftColor}" />
  <SolidColorBrush x:Key="StateUnavailableBrush" Color="{StaticResource StateUnavailableColor}" />
  <SolidColorBrush x:Key="StateUnavailableSoftBrush" Color="{StaticResource StateUnavailableSoftColor}" />
  <Color x:Key="ModalScrimColor">#D90C1017</Color>
  <SolidColorBrush x:Key="ModalScrimBrush" Color="{StaticResource ModalScrimColor}" />

  <!-- Spacing (4px grid). Use these instead of literal Margin/Padding
       numbers in new XAML; the odd 7s and 13s scattered through the
       pages migrate here as each page is touched. -->
  <Thickness x:Key="Space1">4</Thickness>
  <Thickness x:Key="Space2">8</Thickness>
  <Thickness x:Key="Space3">12</Thickness>
  <Thickness x:Key="Space4">16</Thickness>
  <Thickness x:Key="Space6">24</Thickness>
  <Thickness x:Key="StackGap">0,12,0,0</Thickness>
  <Thickness x:Key="BadgePadding">9,4,9,4</Thickness>
  <Thickness x:Key="BannerPadding">13,11,13,11</Thickness>

  <!-- Radius ramp, matching what the app already ships: glass cards 11,
       inset cards 10, badges/pills 12, buttons 18 (stadium). -->
  <CornerRadius x:Key="RadiusCard">11</CornerRadius>
  <CornerRadius x:Key="RadiusInset">10</CornerRadius>
  <CornerRadius x:Key="RadiusBadge">12</CornerRadius>
  <CornerRadius x:Key="RadiusButton">18</CornerRadius>

  <!-- Type ramp. Data readouts use a monospace face with even digit
       widths so live values do not jitter as they update. -->
  <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>
  <FontFamily x:Key="UiDisplayFont">Segoe UI Variable Display, Segoe UI</FontFamily>
  <FontFamily x:Key="DataFont">Cascadia Mono, Consolas</FontFamily>

  <Style x:Key="TypeCaption" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
  </Style>
  <Style x:Key="TypeBody" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style x:Key="TypeBodyStrong" TargetType="TextBlock" BasedOn="{StaticResource TypeBody}">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style x:Key="TypeDataReadout" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DataFont}" />
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <!-- StatusBadge: set Content to the capability state word. Icon +
       word + colour together (never colour alone), and the state is
       announced to UI Automation. Unknown strings fall back to the
       neutral treatment rather than failing silently. -->
  <Style x:Key="StatusBadgeStyle" TargetType="ContentControl">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="AutomationProperties.Name"
            Value="{Binding Content, RelativeSource={RelativeSource Self}, StringFormat=Capability state: {0}}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Border x:Name="Pill" Background="{DynamicResource StateUnavailableSoftBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  CornerRadius="{StaticResource RadiusBadge}" Padding="{StaticResource BadgePadding}">
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="Glyph" Text="&#xE9CE;" FontFamily="{DynamicResource IconFont}"
                         FontSize="11" Margin="0,1,5,0" VerticalAlignment="Center"
                         Foreground="{DynamicResource StateUnavailableBrush}" />
              <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                         FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource StateUnavailableBrush}" />
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="Content" Value="Verified">
              <Setter TargetName="Pill" Property="Background" Value="{DynamicResource StateVerifiedSoftBrush}" />
              <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource StateVerifiedBrush}" />
              <Setter TargetName="Glyph" Property="Text" Value="&#xE73E;" />
              <Setter TargetName="Glyph" Property="Foreground" Value="{DynamicResource StateVerifiedBrush}" />
              <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource StateVerifiedBrush}" />
            </Trigger>
            <Trigger Property="Content" Value="Experimental">
              <Setter TargetName="Pill" Property="Background" Value="{DynamicResource StateExperimentalSoftBrush}" />
              <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource StateExperimentalBrush}" />
              <Setter TargetName="Glyph" Property="Text" Value="&#xE7BA;" />
              <Setter TargetName="Glyph" Property="Foreground" Value="{DynamicResource StateExperimentalBrush}" />
              <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource StateExperimentalBrush}" />
            </Trigger>
            <Trigger Property="Content" Value="Blocked">
              <Setter TargetName="Pill" Property="Background" Value="{DynamicResource StateBlockedSoftBrush}" />
              <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource StateBlockedBrush}" />
              <Setter TargetName="Glyph" Property="Text" Value="&#xE72E;" />
              <Setter TargetName="Glyph" Property="Foreground" Value="{DynamicResource StateBlockedBrush}" />
              <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource StateBlockedBrush}" />
            </Trigger>
            <!-- Supported: a shipping feature that works but has no firmware
                 read-back, so it is confirmed by sight rather than by an API
                 read. Green (it is safe and working, never a risk state like
                 Experimental), with the eye glyph to name the visual-confirmation
                 nature honestly. -->
            <Trigger Property="Content" Value="Supported">
              <Setter TargetName="Pill" Property="Background" Value="{DynamicResource StateVerifiedSoftBrush}" />
              <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource StateVerifiedBrush}" />
              <Setter TargetName="Glyph" Property="Text" Value="&#xE7B3;" />
              <Setter TargetName="Glyph" Property="Foreground" Value="{DynamicResource StateVerifiedBrush}" />
              <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource StateVerifiedBrush}" />
            </Trigger>
            <Trigger Property="Content" Value="ReadOnly">
              <Setter TargetName="Glyph" Property="Text" Value="&#xE7B3;" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
